    "tool_call_id": "call_cbac5c2056d74b74b4c71fd4",
    "name": "localhost_8027_mcp_sandbox_str_replace_editor",
    "content": "{\n  \"command\": \"view\",\n  \"path\": \"/mnt/skills/mailbox-ops/scripts/mailbox_ops.py\",\n  \"output\": \"Here's the result of running `cat -n` on /mnt/skills/mailbox-ops/scripts/mailbox_ops.py:\\n     1\\t\\\"\\\"\\\"\\n     2\\tmailbox-ops Skill 脚本\\n     3\\t数字员工之间的邮箱通信：send_mail / read_inbox / mark_done / mark_done_all / reset_stale\\n     4\\t\\n     5\\t三态状态机：unread → in_progress → done\\n     6\\t  - send_mail:  写入 status=\\\"unread\\\"\\n     7\\t  - read_inbox: 取走 unread 消息，原子标记为 in_progress\\n     8\\t  - mark_done:  将指定消息从 in_progress → done\\n     9\\t  - mark_done_all: 将该角色所有 in_progress → done\\n    10\\t  - reset_stale: 超时的 in_progress → unread（崩溃恢复）\\n    11\\t\\n    12\\t在 AIO-Sandbox 中通过命令行调用：\\n    13\\t  python3 mailbox_ops.py send_mail --mailbox-dir /mnt/shared/mailboxes --to pm --from manager ...\\n    14\\t  python3 mailbox_ops.py read_inbox --mailbox-dir /mnt/shared/mailboxes --role pm\\n    15\\t  python3 mailbox_ops.py mark_done --mailbox-dir /mnt/shared/mailboxes --role pm --msg-ids id1,id2\\n    16\\t  python3 mailbox_ops.py mark_done_all --mailbox-dir /mnt/shared/mailboxes --role pm\\n    17\\t  python3 mailbox_ops.py reset_stale --mailbox-dir /mnt/shared/mailboxes --role pm --timeout 900\\n    18\\t\\\"\\\"\\\"\\n    19\\t\\n    20\\tfrom __future__ import annotations\\n    21\\t\\n    22\\timport argparse\\n    23\\timport json\\n    24\\timport sys\\n    25\\timport uuid\\n    26\\tfrom datetime import datetime, timezone\\n    27\\tfrom pathlib import Path\\n    28\\t\\n    29\\ttry:\\n    30\\t    from filelock import FileLock, Timeout as FileLockTimeout\\n    31\\t    _HAS_FILELOCK = True\\n    32\\texcept ImportError:\\n    33\\t    _HAS_FILELOCK = False\\n    34\\t\\n    35\\t_VALID_ROLES = {\\\"manager\\\", \\\"pm\\\", \\\"dev\\\", \\\"qa\\\"}\\n    36\\t_LOCK_TIMEOUT = 10\\n    37\\t\\n    38\\tSTATUS_UNREAD = \\\"unread\\\"\\n    39\\tSTATUS_IN_PROGRESS = \\\"in_progress\\\"\\n    40\\tSTATUS_DONE = \\\"done\\\"\\n    41\\t\\n    42\\t\\n    43\\tdef _ok(data: dict) -> None:\\n    44\\t    print(json.dumps({\\\"errcode\\\": 0, \\\"errmsg\\\": \\\"success\\\", **data}, ensure_ascii=False))\\n    45\\t\\n    46\\t\\n    47\\tdef _err(code: int, msg: str) -> None:\\n    48\\t    print(json.dumps({\\\"errcode\\\": code, \\\"errmsg\\\": msg}, ensure_ascii=False))\\n    49\\t    sys.exit(1)\\n    50\\t\\n    51\\t\\n    52\\tdef _inbox_path(mailbox_dir: Path, role: str) -> Path:\\n    53\\t    return mailbox_dir / f\\\"{role}.json\\\"\\n    54\\t\\n    55\\t\\n    56\\tdef _lock_path(inbox: Path) -> Path:\\n    57\\t    return inbox.with_suffix(\\\".lock\\\")\\n    58\\t\\n    59\\t\\n    60\\tdef _read_file(inbox: Path) -> list[dict]:\\n    61\\t    inbox.parent.mkdir(parents=True, exist_ok=True)\\n    62\\t    if not inbox.exists():\\n    63\\t        inbox.write_text(\\\"[]\\\", encoding=\\\"utf-8\\\")\\n    64\\t        return []\\n    65\\t    return json.loads(inbox.read_text(encoding=\\\"utf-8\\\"))\\n    66\\t\\n    67\\t\\n    68\\tdef _write_file(inbox: Path, messages: list[dict]) -> None:\\n    69\\t    inbox.write_text(json.dumps(messages, ensure_ascii=False, indent=2),\\n    70\\t                     encoding=\\\"utf-8\\\")\\n    71\\t\\n    72\\t\\n    73\\tdef _now_iso() -> str:\\n    74\\t    return datetime.now(timezone.utc).isoformat()\\n    75\\t\\n    76\\t\\n    77\\tdef _with_lock(inbox: Path, fn):\\n    78\\t    lock = _lock_path(inbox)\\n    79\\t    if _HAS_FILELOCK:\\n    80\\t        try:\\n    81\\t            with FileLock(str(lock), timeout=_LOCK_TIMEOUT):\\n    82\\t                return fn()\\n    83\\t        except FileLockTimeout:\\n    84\\t            _err(2, f\\\"获取文件锁超时（>{_LOCK_TIMEOUT}s），请稍后重试\\\")\\n    85\\t    else:\\n    86\\t        return fn()\\n    87\\t\\n    88\\t\\n    89\\tdef cmd_send_mail(args: argparse.Namespace) -> None:\\n    90\\t    mailbox_dir = Path(args.mailbox_dir)\\n    91\\t    to = args.to.lower()\\n    92\\t    from_ = getattr(args, \\\"from\\\").lower()\\n    93\\t\\n    94\\t    if to not in _VALID_ROLES:\\n    95\\t        _err(1, f\\\"无效的收件人角色 '{to}'，允许值：{_VALID_ROLES}\\\")\\n    96\\t    if from_ not in _VALID_ROLES:\\n    97\\t        _err(1, f\\\"无效的发件人角色 '{from_}'，允许值：{_VALID_ROLES}\\\")\\n    98\\t\\n    99\\t    inbox = _inbox_path(mailbox_dir, to)\\n   100\\t    msg_id = str(uuid.uuid4())\\n   101\\t\\n   102\\t    message = {\\n   103\\t        \\\"id\\\": msg_id,\\n   104\\t        \\\"from\\\": from_,\\n   105\\t        \\\"to\\\": to,\\n   106\\t        \\\"type\\\": args.type,\\n   107\\t        \\\"subject\\\": args.subject,\\n   108\\t        \\\"content\\\": args.content,\\n   109\\t        \\\"timestamp\\\": _now_iso(),\\n   110\\t        \\\"status\\\": STATUS_UNREAD,\\n   111\\t        \\\"processing_since\\\": None,\\n   112\\t    }\\n   113\\t\\n   114\\t    def do():\\n   115\\t        messages = _read_file(inbox)\\n   116\\t        messages.append(message)\\n   117\\t        _write_file(inbox, messages)\\n   118\\t\\n   119\\t    _with_lock(inbox, do)\\n   120\\t    _ok({\\\"msg_id\\\": msg_id})\\n   121\\t\\n   122\\t\\n   123\\tdef cmd_read_inbox(args: argparse.Namespace) -> None:\\n   124\\t    mailbox_dir = Path(args.mailbox_dir)\\n   125\\t    role = args.role.lower()\\n   126\\t\\n   127\\t    if role not in _VALID_ROLES:\\n   128\\t        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n   129\\t\\n   130\\t    inbox = _inbox_path(mailbox_dir, role)\\n   131\\t    result = {\\\"messages\\\": []}\\n   132\\t\\n   133\\t    def do():\\n   134\\t        messages = _read_file(inbox)\\n   135\\t        unread = [dict(m) for m in messages if m.get(\\\"status\\\", \\\"unread\\\") == STATUS_UNREAD]\\n   136\\t        now = _now_iso()\\n   137\\t        for m in messages:\\n   138\\t            if m.get(\\\"status\\\", \\\"unread\\\") == STATUS_UNREAD:\\n   139\\t                m[\\\"status\\\"] = STATUS_IN_PROGRESS\\n   140\\t                m[\\\"processing_since\\\"] = now\\n   141\\t        _write_file(inbox, messages)\\n   142\\t        result[\\\"messages\\\"] = unread\\n   143\\t\\n   144\\t    _with_lock(inbox, do)\\n   145\\t    _ok(result)\\n   146\\t\\n   147\\t\\n   148\\tdef cmd_mark_done(args: argparse.Namespace) -> None:\\n   149\\t    mailbox_dir = Path(args.mailbox_dir)\\n   150\\t    role = args.role.lower()\\n   151\\t\\n   152\\t    if role not in _VALID_ROLES:\\n   153\\t        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n   154\\t\\n   155\\t    msg_ids = set(args.msg_ids.split(\\\",\\\"))\\n   156\\t    inbox = _inbox_path(mailbox_dir, role)\\n   157\\t    result = {\\\"marked\\\": 0}\\n   158\\t\\n   159\\t    def do():\\n   160\\t        messages = _read_file(inbox)\\n   161\\t        count = 0\\n   162\\t        for m in messages:\\n   163\\t            if m.get(\\\"id\\\") in msg_ids and m.get(\\\"status\\\") == STATUS_IN_PROGRESS:\\n   164\\t                m[\\\"status\\\"] = STATUS_DONE\\n   165\\t                count += 1\\n   166\\t        _write_file(inbox, messages)\\n   167\\t        result[\\\"marked\\\"] = count\\n   168\\t\\n   169\\t    _with_lock(inbox, do)\\n   170\\t    _ok(result)\\n   171\\t\\n   172\\t\\n   173\\tdef cmd_mark_done_all(args: argparse.Namespace) -> None:\\n   174\\t    mailbox_dir = Path(args.mailbox_dir)\\n   175\\t    role = args.role.lower()\\n   176\\t\\n   177\\t    if role not in _VALID_ROLES:\\n   178\\t        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n   179\\t\\n   180\\t    inbox = _inbox_path(mailbox_dir, role)\\n   181\\t    result = {\\\"marked\\\": 0}\\n   182\\t\\n   183\\t    def do():\\n   184\\t        messages = _read_file(inbox)\\n   185\\t        count = 0\\n   186\\t        for m in messages:\\n   187\\t            if m.get(\\\"status\\\") == STATUS_IN_PROGRESS:\\n   188\\t                m[\\\"status\\\"] = STATUS_DONE\\n   189\\t                count += 1\\n   190\\t        _write_file(inbox, messages)\\n   191\\t        result[\\\"marked\\\"] = count\\n   192\\t\\n   193\\t    _with_lock(inbox, do)\\n   194\\t    _ok(result)\\n   195\\t\\n   196\\t\\n   197\\tdef cmd_reset_stale(args: argparse.Namespace) -> None:\\n   198\\t    mailbox_dir = Path(args.mailbox_dir)\\n   199\\t    role = args.role.lower()\\n   200\\t    timeout = args.timeout\\n   201\\t\\n   202\\t    if role not in _VALID_ROLES:\\n   203\\t        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n   204\\t\\n   205\\t    inbox = _inbox_path(mailbox_dir, role)\\n   206\\t    result = {\\\"reset\\\": 0}\\n   207\\t    now = datetime.now(timezone.utc)\\n   208\\t\\n   209\\t    def do():\\n   210\\t        messages = _read_file(inbox)\\n   211\\t        count = 0\\n   212\\t        for m in messages:\\n   213\\t            if m.get(\\\"status\\\") != STATUS_IN_PROGRESS:\\n   214\\t                continue\\n   215\\t            since_str = m.get(\\\"processing_since\\\")\\n   216\\t            if not since_str:\\n   217\\t                m[\\\"status\\\"] = STATUS_UNREAD\\n   218\\t                m[\\\"processing_since\\\"] = None\\n   219\\t                count += 1\\n   220\\t                continue\\n   221\\t            since = datetime.fromisoformat(since_str)\\n   222\\t            if (now - since).total_seconds() >= timeout:\\n   223\\t                m[\\\"status\\\"] = STATUS_UNREAD\\n   224\\t                m[\\\"processing_since\\\"] = None\\n   225\\t                count += 1\\n   226\\t        _write_file(inbox, messages)\\n   227\\t        result[\\\"reset\\\"] = count\\n   228\\t\\n   229\\t    _with_lock(inbox, do)\\n   230\\t    _ok(result)\\n   231\\t\\n   232\\t\\n   233\\tdef main() -> None:\\n   234\\t    parser = argparse.ArgumentParser(description=\\\"mailbox-ops: 数字员工邮箱操作（三态状态机）\\\")\\n   235\\t    sub = parser.add_subparsers(dest=\\\"command\\\")\\n   236\\t\\n   237\\t    p_send = sub.add_parser(\\\"send_mail\\\", help=\\\"发送消息到指定角色的邮箱\\\")\\n   238\\t    p_send.add_argument(\\\"--mailbox-dir\\\", required=True)\\n   239\\t    p_send.add_argument(\\\"--to\\\", required=True)\\n   240\\t    p_send.add_argument(\\\"--from\\\", required=True, dest=\\\"from\\\")\\n   241\\t    p_send.add_argument(\\\"--type\\\", required=True)\\n   242\\t    p_send.add_argument(\\\"--subject\\\", required=True)\\n   243\\t    p_send.add_argument(\\\"--content\\\", required=True)\\n   244\\t\\n   245\\t    p_read = sub.add_parser(\\\"read_inbox\\\", help=\\\"读取 unread 消息（标记为 in_progress）\\\")\\n   246\\t    p_read.add_argument(\\\"--mailbox-dir\\\", required=True)\\n   247\\t    p_read.add_argument(\\\"--role\\\", required=True)\\n   248\\t\\n   249\\t    p_done = sub.add_parser(\\\"mark_done\\\", help=\\\"将指定消息标记为 done\\\")\\n   250\\t    p_done.add_argument(\\\"--mailbox-dir\\\", required=True)\\n   251\\t    p_done.add_argument(\\\"--role\\\", required=True)\\n   252\\t    p_done.add_argument(\\\"--msg-ids\\\", required=True, help=\\\"逗号分隔的消息 ID\\\")\\n   253\\t\\n   254\\t    p_done_all = sub.add_parser(\\\"mark_done_all\\\", help=\\\"将所有 in_progress 消息标记为 done\\\")\\n   255\\t    p_done_all.add_argument(\\\"--mailbox-dir\\\", required=True)\\n   256\\t    p_done_all.add_argument(\\\"--role\\\", required=True)\\n   257\\t\\n   258\\t    p_reset = sub.add_parser(\\\"reset_stale\\\", help=\\\"超时 in_progress → unread（崩溃恢复）\\\")\\n   259\\t    p_reset.add_argument(\\\"--mailbox-dir\\\", required=True)\\n   260\\t    p_reset.add_argument(\\\"--role\\\", required=True)\\n   261\\t    p_reset.add_argument(\\\"--timeout\\\", type=int, default=900, help=\\\"超时秒数（默认 900）\\\")\\n   262\\t\\n   263\\t    args = parser.parse_args()\\n   264\\t\\n   265\\t    cmds = {\\n   266\\t        \\\"send_mail\\\": cmd_send_mail,\\n   267\\t        \\\"read_inbox\\\": cmd_read_inbox,\\n   268\\t        \\\"mark_done\\\": cmd_mark_done,\\n   269\\t        \\\"mark_done_all\\\": cmd_mark_done_all,\\n   270\\t        \\\"reset_stale\\\": cmd_reset_stale,\\n   271\\t    }\\n   272\\t    if args.command in cmds:\\n   273\\t        cmds[args.command](args)\\n   274\\t    else:\\n   275\\t        parser.print_help()\\n   276\\t        sys.exit(1)\\n   277\\t\\n   278\\t\\n   279\\tif __name__ == \\\"__main__\\\":\\n   280\\t    main()\\n   281\\t\\n\",\n  \"error\": null,\n  \"prev_exist\": true,\n  \"old_content\": \"\\\"\\\"\\\"\\nmailbox-ops Skill 脚本\\n数字员工之间的邮箱通信：send_mail / read_inbox / mark_done / mark_done_all / reset_stale\\n\\n三态状态机：unread → in_progress → done\\n  - send_mail:  写入 status=\\\"unread\\\"\\n  - read_inbox: 取走 unread 消息，原子标记为 in_progress\\n  - mark_done:  将指定消息从 in_progress → done\\n  - mark_done_all: 将该角色所有 in_progress → done\\n  - reset_stale: 超时的 in_progress → unread（崩溃恢复）\\n\\n在 AIO-Sandbox 中通过命令行调用：\\n  python3 mailbox_ops.py send_mail --mailbox-dir /mnt/shared/mailboxes --to pm --from manager ...\\n  python3 mailbox_ops.py read_inbox --mailbox-dir /mnt/shared/mailboxes --role pm\\n  python3 mailbox_ops.py mark_done --mailbox-dir /mnt/shared/mailboxes --role pm --msg-ids id1,id2\\n  python3 mailbox_ops.py mark_done_all --mailbox-dir /mnt/shared/mailboxes --role pm\\n  python3 mailbox_ops.py reset_stale --mailbox-dir /mnt/shared/mailboxes --role pm --timeout 900\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport argparse\\nimport json\\nimport sys\\nimport uuid\\nfrom datetime import datetime, timezone\\nfrom pathlib import Path\\n\\ntry:\\n    from filelock import FileLock, Timeout as FileLockTimeout\\n    _HAS_FILELOCK = True\\nexcept ImportError:\\n    _HAS_FILELOCK = False\\n\\n_VALID_ROLES = {\\\"manager\\\", \\\"pm\\\", \\\"dev\\\", \\\"qa\\\"}\\n_LOCK_TIMEOUT = 10\\n\\nSTATUS_UNREAD = \\\"unread\\\"\\nSTATUS_IN_PROGRESS = \\\"in_progress\\\"\\nSTATUS_DONE = \\\"done\\\"\\n\\n\\ndef _ok(data: dict) -> None:\\n    print(json.dumps({\\\"errcode\\\": 0, \\\"errmsg\\\": \\\"success\\\", **data}, ensure_ascii=False))\\n\\n\\ndef _err(code: int, msg: str) -> None:\\n    print(json.dumps({\\\"errcode\\\": code, \\\"errmsg\\\": msg}, ensure_ascii=False))\\n    sys.exit(1)\\n\\n\\ndef _inbox_path(mailbox_dir: Path, role: str) -> Path:\\n    return mailbox_dir / f\\\"{role}.json\\\"\\n\\n\\ndef _lock_path(inbox: Path) -> Path:\\n    return inbox.with_suffix(\\\".lock\\\")\\n\\n\\ndef _read_file(inbox: Path) -> list[dict]:\\n    inbox.parent.mkdir(parents=True, exist_ok=True)\\n    if not inbox.exists():\\n        inbox.write_text(\\\"[]\\\", encoding=\\\"utf-8\\\")\\n        return []\\n    return json.loads(inbox.read_text(encoding=\\\"utf-8\\\"))\\n\\n\\ndef _write_file(inbox: Path, messages: list[dict]) -> None:\\n    inbox.write_text(json.dumps(messages, ensure_ascii=False, indent=2),\\n                     encoding=\\\"utf-8\\\")\\n\\n\\ndef _now_iso() -> str:\\n    return datetime.now(timezone.utc).isoformat()\\n\\n\\ndef _with_lock(inbox: Path, fn):\\n    lock = _lock_path(inbox)\\n    if _HAS_FILELOCK:\\n        try:\\n            with FileLock(str(lock), timeout=_LOCK_TIMEOUT):\\n                return fn()\\n        except FileLockTimeout:\\n            _err(2, f\\\"获取文件锁超时（>{_LOCK_TIMEOUT}s），请稍后重试\\\")\\n    else:\\n        return fn()\\n\\n\\ndef cmd_send_mail(args: argparse.Namespace) -> None:\\n    mailbox_dir = Path(args.mailbox_dir)\\n    to = args.to.lower()\\n    from_ = getattr(args, \\\"from\\\").lower()\\n\\n    if to not in _VALID_ROLES:\\n        _err(1, f\\\"无效的收件人角色 '{to}'，允许值：{_VALID_ROLES}\\\")\\n    if from_ not in _VALID_ROLES:\\n        _err(1, f\\\"无效的发件人角色 '{from_}'，允许值：{_VALID_ROLES}\\\")\\n\\n    inbox = _inbox_path(mailbox_dir, to)\\n    msg_id = str(uuid.uuid4())\\n\\n    message = {\\n        \\\"id\\\": msg_id,\\n        \\\"from\\\": from_,\\n        \\\"to\\\": to,\\n        \\\"type\\\": args.type,\\n        \\\"subject\\\": args.subject,\\n        \\\"content\\\": args.content,\\n        \\\"timestamp\\\": _now_iso(),\\n        \\\"status\\\": STATUS_UNREAD,\\n        \\\"processing_since\\\": None,\\n    }\\n\\n    def do():\\n        messages = _read_file(inbox)\\n        messages.append(message)\\n        _write_file(inbox, messages)\\n\\n    _with_lock(inbox, do)\\n    _ok({\\\"msg_id\\\": msg_id})\\n\\n\\ndef cmd_read_inbox(args: argparse.Namespace) -> None:\\n    mailbox_dir = Path(args.mailbox_dir)\\n    role = args.role.lower()\\n\\n    if role not in _VALID_ROLES:\\n        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n\\n    inbox = _inbox_path(mailbox_dir, role)\\n    result = {\\\"messages\\\": []}\\n\\n    def do():\\n        messages = _read_file(inbox)\\n        unread = [dict(m) for m in messages if m.get(\\\"status\\\", \\\"unread\\\") == STATUS_UNREAD]\\n        now = _now_iso()\\n        for m in messages:\\n            if m.get(\\\"status\\\", \\\"unread\\\") == STATUS_UNREAD:\\n                m[\\\"status\\\"] = STATUS_IN_PROGRESS\\n                m[\\\"processing_since\\\"] = now\\n        _write_file(inbox, messages)\\n        result[\\\"messages\\\"] = unread\\n\\n    _with_lock(inbox, do)\\n    _ok(result)\\n\\n\\ndef cmd_mark_done(args: argparse.Namespace) -> None:\\n    mailbox_dir = Path(args.mailbox_dir)\\n    role = args.role.lower()\\n\\n    if role not in _VALID_ROLES:\\n        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n\\n    msg_ids = set(args.msg_ids.split(\\\",\\\"))\\n    inbox = _inbox_path(mailbox_dir, role)\\n    result = {\\\"marked\\\": 0}\\n\\n    def do():\\n        messages = _read_file(inbox)\\n        count = 0\\n        for m in messages:\\n            if m.get(\\\"id\\\") in msg_ids and m.get(\\\"status\\\") == STATUS_IN_PROGRESS:\\n                m[\\\"status\\\"] = STATUS_DONE\\n                count += 1\\n        _write_file(inbox, messages)\\n        result[\\\"marked\\\"] = count\\n\\n    _with_lock(inbox, do)\\n    _ok(result)\\n\\n\\ndef cmd_mark_done_all(args: argparse.Namespace) -> None:\\n    mailbox_dir = Path(args.mailbox_dir)\\n    role = args.role.lower()\\n\\n    if role not in _VALID_ROLES:\\n        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n\\n    inbox = _inbox_path(mailbox_dir, role)\\n    result = {\\\"marked\\\": 0}\\n\\n    def do():\\n        messages = _read_file(inbox)\\n        count = 0\\n        for m in messages:\\n            if m.get(\\\"status\\\") == STATUS_IN_PROGRESS:\\n                m[\\\"status\\\"] = STATUS_DONE\\n                count += 1\\n        _write_file(inbox, messages)\\n        result[\\\"marked\\\"] = count\\n\\n    _with_lock(inbox, do)\\n    _ok(result)\\n\\n\\ndef cmd_reset_stale(args: argparse.Namespace) -> None:\\n    mailbox_dir = Path(args.mailbox_dir)\\n    role = args.role.lower()\\n    timeout = args.timeout\\n\\n    if role not in _VALID_ROLES:\\n        _err(1, f\\\"无效的角色 '{role}'，允许值：{_VALID_ROLES}\\\")\\n\\n    inbox = _inbox_path(mailbox_dir, role)\\n    result = {\\\"reset\\\": 0}\\n    now = datetime.now(timezone.utc)\\n\\n    def do():\\n        messages = _read_file(inbox)\\n        count = 0\\n        for m in messages:\\n            if m.get(\\\"status\\\") != STATUS_IN_PROGRESS:\\n                continue\\n            since_str = m.get(\\\"processing_since\\\")\\n            if not since_str:\\n                m[\\\"status\\\"] = STATUS_UNREAD\\n                m[\\\"processing_since\\\"] = None\\n                count += 1\\n                continue\\n            since = datetime.fromisoformat(since_str)\\n            if (now - since).total_seconds() >= timeout:\\n                m[\\\"status\\\"] = STATUS_UNREAD\\n                m[\\\"processing_since\\\"] = None\\n                count += 1\\n        _write_file(inbox, messages)\\n        result[\\\"reset\\\"] = count\\n\\n    _with_lock(inbox, do)\\n    _ok(result)\\n\\n\\ndef main() -> None:\\n    parser = argparse.ArgumentParser(description=\\\"mailbox-ops: 数字员工邮箱操作（三态状态机）\\\")\\n    sub = parser.add_subparsers(dest=\\\"command\\\")\\n\\n    p_send = sub.add_parser(\\\"send_mail\\\", help=\\\"发送消息到指定角色的邮箱\\\")\\n    p_send.add_argument(\\\"--mailbox-dir\\\", required=True)\\n    p_send.add_argument(\\\"--to\\\", required=True)\\n    p_send.add_argument(\\\"--from\\\", required=True, dest=\\\"from\\\")\\n    p_send.add_argument(\\\"--type\\\", required=True)\\n    p_send.add_argument(\\\"--subject\\\", required=True)\\n    p_send.add_argument(\\\"--content\\\", required=True)\\n\\n    p_read = sub.add_parser(\\\"read_inbox\\\", help=\\\"读取 unread 消息（标记为 in_progress）\\\")\\n    p_read.add_argument(\\\"--mailbox-dir\\\", required=True)\\n    p_read.add_argument(\\\"--role\\\", required=True)\\n\\n    p_done = sub.add_parser(\\\"mark_done\\\", help=\\\"将指定消息标记为 done\\\")\\n    p_done.add_argument(\\\"--mailbox-dir\\\", required=True)\\n    p_done.add_argument(\\\"--role\\\", required=True)\\n    p_done.add_argument(\\\"--msg-ids\\\", required=True, help=\\\"逗号分隔的消息 ID\\\")\\n\\n    p_done_all = sub.add_parser(\\\"mark_done_all\\\", help=\\\"将所有 in_progress 消息标记为 done\\\")\\n    p_done_all.add_argument(\\\"--mailbox-dir\\\", required=True)\\n    p_done_all.add_argument(\\\"--role\\\", required=True)\\n\\n    p_reset = sub.add_parser(\\\"reset_stale\\\", help=\\\"超时 in_progress → unread（崩溃恢复）\\\")\\n    p_reset.add_argument(\\\"--mailbox-dir\\\", required=True)\\n    p_reset.add_argument(\\\"--role\\\", required=True)\\n    p_reset.add_argument(\\\"--timeout\\\", type=int, default=900, help=\\\"超时秒数（默认 900）\\\")\\n\\n    args = parser.parse_args()\\n\\n    cmds = {\\n        \\\"send_mail\\\": cmd_send_mail,\\n        \\\"read_inbox\\\": cmd_read_inbox,\\n        \\\"mark_done\\\": cmd_mark_done,\\n        \\\"mark_done_all\\\": cmd_mark_done_all,\\n        \\\"reset_stale\\\": cmd_reset_stale,\\n    }\\n    if args.command in cmds:\\n        cmds[args.command](args)\\n    else:\\n        parser.print_help()\\n        sys.exit(1)\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\\n\",\n  \"new_content\": null,\n  \"success\": true\n}"
