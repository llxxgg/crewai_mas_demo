│  无第三方依赖、≤1秒天然满足、可控可调试可扩展 |                              │
│  覆盖度有限、需持续维护模式库 | ✅ 采用 |\n| 大模型 API |                    │
│  覆盖度高、泛化能力强 | 网络延迟不可控（违反≤1秒）、依赖外部服务 | ❌        │
│  不采用 |\n| 第三方 NLP 库（如 LAC） | 中文分词能力强 |                      │
│  引入第三方依赖、性能不确定 | ❌ 不采用 |\n\n### 3.2                         │
│  核心处理流程\n\n\\`\\`\\`\n输入 text\n  │\n  ├─ 1.                          │
│  预处理：去除多余空白，统一中文标点（，→,）\n  │\n  ├─ 2.                    │
│  extract_time(text, base_date)\n  │     ├─ 2a. 匹配相对日期关键词 →          │
│  resolve_relative_date() 计算目标日期\n  │     ├─ 2b.                        │
│  匹配时间段模式（\\"X点到Y点\\"）→ start + end\n  │     ├─ 2c.               │
│  匹配单时间点模式 → start, end=None\n  │     ├─ 2d. 推断上午/下午：\n  │     │
│  │     含\\"下午/晚上/傍晚\\" → 小时+12\n  │     │                           │
│  含\\"上午/早上/清晨\\" → 小时不变\n  │     │     无关键词 + 小时≤6 →        │
│  默认下午(+12)\n  │     │     无关键词 + 小时>6 → 默认上午(不变)\n  │        │
│  └─ 2e. 若无日期关键词 → 使用 base_date 日期部分\n  │\n  ├─ 3.               │
│  从原文中移除已匹配的时间描述文本 → time_removed_text\n  │\n  ├─ 4.          │
│  extract_location(text)\n  │     ├─ 匹配 \\"地点在X\\" / \\"在X\\" 模式\n    │
│  │     └─ 失败 → \\"\\"\n  │\n  ├─ 5. extract_attendees(text)\n  │     ├─    │
│  匹配 \\"和X\\" / \\"与X\\" 模式（X为人名关键词）\n  │     └─ 失败 → []\n    │
│  │\n  ├─ 6. extract_title(text, time_removed_text)\n  │     ├─ 从            │
│  time_removed_text 中移除地点和参与人描述\n  │     ├─ 去除残余标点和空白\n   │
│  │     ├─ 剩余文本作为标题\n  │     └─ 若标题为空 → \\"未命名事件\\"\n  │\n  │
│  └─ 7. 组装返回 dict\n       ├─ start_time/end_time → ISO 8601 格式化（带    │
│  +08:00 时区）\n       ├─ end_time 为 None → start_time +                    │
│  timedelta(hours=1)\n       ├─ start_time 为 None → start_time=\\"\\" ,      │
│  end_time=\\"\\"\n       └─ location/attendees 直接填入\n\\`\\`\\`\n\n###    │
│  3.3 关键正则模式定义（patterns.py）\n\n\\`\\`\\`python\nimport re\n\n#      │
│  ===== 相对日期模式 =====\n# 每个条目为 (关键词,                             │
│  预编译正则)\nRELATIVE_DATE_PATTERNS: list[tuple[str, re.Pattern[str]]] =    │
│  [\n    (\\"明天\\",     re.compile(r\\"明天\\")),\n    (\\"后天\\",         │
│  re.compile(r\\"后天\\")),\n    (\\"今天\\",                                 │
│  re.compile(r\\"今天\\")),\n    (\\"下周一\\",                               │
│  re.compile(r\\"下周一\\")),\n    (\\"下周二\\",                             │
│  re.compile(r\\"下周二\\")),\n    (\\"下周三\\",                             │
│  re.compile(r\\"下周三\\")),\n    (\\"下周四\\",                             │
│  re.compile(r\\"下周四\\")),\n    (\\"下周五\\",                             │
│  re.compile(r\\"下周五\\")),\n    (\\"下周六\\",                             │
│  re.compile(r\\"下周六\\")),\n    (\\"下周日\\",                             │
│  .compile(r\\"下周日|下周天\\")),\n    (\\"这个周五\\",                      │
│  re.compile(r\\"这个周五|这周五|本周五\\")),\n    (\\"这个周一\\",           │
│  re.compile(r\\"这个周一|这周一|本周一\\")),\n    (\\"这个周二\\",           │
│  re.compile(r\\"这个周二|这周二|本周二\\")),\n    (\\"这个周三\\",           │
│  re.compile(r\\"这个周三|这周三|本周三\\")),\n    (\\"这个周四\\",           │
│  re.compile(r\\"这个周四|这周四|本周四\\")),\n    (\\"这个周六\\",           │
│  re.compile(r\\"这个周六|这周六|本周六\\")),\n    (\\"这个周日\\",           │
│  re.compile(r\\"这个周日|这周日|本周日|这周天|本周天\\")),\n]\n\n# =====     │
│  时间段模式（优先匹配，避免被单时间点截断） =====\nTIME_RANGE_PATTERN:       │
│  re.Pattern[str] = re.compile(\n                                             │
│  r\\"(上午|下午|晚上|傍晚)?(\\d{1,2})点(?:半)?(?:到|至|-|—)\\"\n             │
│  r\\"(上午|下午|晚上|傍晚)?(\\d{1,2})点(?:半)?\\"\n)\n\n# =====              │
│  单时间点模式 =====\nTIME_POINT_PATTERN: re.Pattern[str] = re.compile(\n     │
│  r\\"(上午|下午|晚上|傍晚|早上|清晨)(\\d{1,2})点(?:半)?\\"\n                 │
│  r\\"|(\\d{1,2})点(?:半)?\\"\n)\n\n# ===== 地点模式                          │
│  =====\nLOCATION_PATTERN: re.Pattern[str] = re.compile(\n                    │
│  r\\"地点在(.+?)(?:[，,。.]|$)\\"\n                                          │
│  r\\"|在(.+?)(?:[，,。.]|$)\\"\n)\n\n# ===== 参与人模式                      │
│  =====\nATTENDEE_PATTERN: re.Pattern[str] = re.compile(\n                    │
│  r\\"和(.+?)(?:[，,。.地点]|$)\\"\n                                          │
│  r\\"|与(.+?)(?:[，,。.地点]|$)\\"\n)\n\\`\\`\\`\n\n### 3.4                  │
│  相对时间计算核心逻辑\n\n\\`\\`\\`python\nfrom datetime import datetime,     │
│  timedelta\nfrom zoneinfo import ZoneInfo\n\nSHANGHAI_TZ =                   │
│  ZoneInfo(\\"Asia/Shanghai\\")\n\nWEEKDAY_MAP: dict[str, int] = {\n          │
│  \\"一\\": 0, \\"二\\": 1, \\"三\\": 2, \\"四\\": 3,\n    \\"五\\": 4,       │
│  \\"六\\": 5, \\"日\\": 6, \\"天\\": 6,\n}\n\ndef                            │
│  resolve_relative_date(keyword: str, base_date: datetime) -> datetime:\n     │
│  \\"\\"\\"根据相对日期关键词计算目标日期（保留 base_date                     │
│  的时间部分）\\"\\"\\"\n    if keyword == \\"今天\\":\n        return        │
│  base_date\n    elif keyword == \\"明天\\":\n        return base_date +      │
│  timedelta(days=1)\n    elif keyword == \\"后天\\":\n        return          │
│  base_date + timedelta(days=2)\n    elif keyword.startswith(\\"下周\\"):\n   │
│  # 下周X：先跳到下周一，再加 weekday 偏移\n        target_weekday =          │
│  WEEKDAY_MAP[keyword[2]]\n        days_to_next_monday = (7 -                 │
│  base_date.weekday()) % 7 or 7\n        days_ahead = days_to_next_monday +   │
│  target_weekday\n        return base_date + timedelta(days=days_ahead)\n     │
│  elif keyword.startswith(\\"这个\\") or keyword.startswith(\\"这\\") or      │
│  keyword.startswith(\\"本周\\"):\n        #                                  │
│  本周X：计算本周目标星期几的日期\n        suffix = keyword[-1]  #            │
│  取最后一个字符：一/二/.../日/天\n        target_weekday =                   │
│  WEEKDAY_MAP[suffix]\n        days_diff = target_weekday -                   │
│  base_date.weekday()\n        if days_diff < 0:\n            days_diff += 7  │
│  # 已过则取下周\n        return base_date + timedelta(days=days_diff)\n      │
│  else:\n        raise ParseError(f\\"未知的相对日期关键词:                   │
│  {keyword}\\")\n\\`\\`\\`\n\n### 3.5 时间推断策略\n\n| 场景 | 规则 | 示例    │
│  |\n|------|------|------|\n| 含\\"下午/晚上/傍晚\\" | 小时数 +12 |          │
│  \\"下午3点\\" → 15:00 |\n| 含\\"上午/早上/清晨\\" | 小时数不变 |            │
│  \\"上午10点\\" → 10:00 |\n| 无关键词 + 小时 ≤ 6 | 默认视为下午(+12) |       │
│  \\"3点\\" → 15:00 |\n| 无关键词 + 小时 > 6 | 默认视为上午(不变) |           │
│  \\"10点\\" → 10:00 |\n| 含\\"点半\\" | 分钟设为 30 | \\"下午3点半\\" →      │
│  15:30 |\n\n### 3.6 错误处理策略\n\n| 场景 | 处理方式                        │
│  |\n|------|---------|\n| 时间无法解析 | \\`start_time=\\"\\"\\`,            │
│  \\`end_time=\\"\\"\\` |\n| 标题无法提取 | \\`title=\\"未命名事件\\"\\`      │
│  |\n| 地点无法提取 | \\`location=\\"\\"\\` |\n| 参与人无法提取 |             │
│  \\`attendees=[]\\` |\n| 输入为空或纯空白 | 抛出 \\`ValueError\\` |\n|       │
│  内部解析异常 | \\`ParseError\\` 仅用于子模块间流程控制，**不对外抛出**      │
│  |\n\n### 3.7 性能考量\n\n- 所有操作为纯内存计算，无网络/IO，单次解析 ≤1秒   │
│  天然满足\n-                                                                 │
│  正则预编译（\\`re.compile\\`）在模块加载时完成，运行时无编译开销\n-         │
│  子模块按顺序调用，无并发需求\n-                                             │
│  匹配顺序：时间段模式优先于单时间点模式，避免截断\n\n---\n\n## 4.            │
