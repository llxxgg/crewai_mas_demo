   base_date: 相对时间的基准日期时间，默认为当前本地时间（Asia/Shanghai 时区）\\n\\n    Returns:\\n        {\\n            \\\\\\"title\\\\\\": str,           # 事件标题，无法提取时返回 \\\\\\"未命名事件\\\\\\"\\n            \\\\\\"start_time\\\\\\": str,      # ISO 8601 格式，如 \\\\\\"2026-03-27T15:00:00+08:00\\\\\\"；无法解析时返回 \\\\\\"\\\\\\"\\n            \\\\\\"end_time\\\\\\": str,        # ISO 8601 格式；指定范围则用范围结束时间，否则 start_time + 1h；无法解析时返回 \\\\\\"\\\\\\"\\n            \\\\\\"location\\\\\\": str,        # 地点，无法提取时返回 \\\\\\"\\\\\\"\\n            \\\\\\"attendees\\\\\\": list[str]  # 参与人列表，无法提取时返回 []\\n        }\\n\\n    Raises:\\n        ValueError: text 为空字符串或纯空白时抛出\\n    \\\\\\"\\\\\\"\\\\\\"\\n\\\\`\\\\`\\\\`\\n\\n### 2.2 返回数据结构约束\\n\\n\\\\`\\\\`\\\\`python\\n# 字段约束说明：\\n# - title: 非空字符串，无法提取时固定返回 \\\\\\"未命名事件\\\\\\"\\n# - start_time: ISO 8601 带时区字符串，无法解析时间时返回空字符串 \\\\\\"\\\\\\"\\n# - end_time: ISO 8601 带时区字符串，无法解析时返回空字符串 \\\\\\"\\\\\\"\\n#   - 若输入指定时间范围（\\\\\\"2点到4点\\\\\\"），end_time = 范围结束时间\\n#   - 若输入仅指定单时间点，end_time = start_time + 1小时（默认1小时）\\n# - location: 字符串，无法提取时返回 \\\\\\"\\\\\\"\\n# - attendees: 字符串列表，无法提取时返回 []\\n\\\\`\\\\`\\\\`\\n\\n### 2.3 子模块接口\\n\\n\\\\`\\\\`\\\\`python\\n# time_extractor.py\\ndef extract_time(text: str, base_date: datetime) -> tuple[datetime | None, datetime | None]:\\n    \\\\\\"\\\\\\"\\\\\\"\\n    从文本中提取时间信息。\\n\\n    Args:\\n        text: 原始输入文本\\n        base_date: 相对时间基准日期\\n\\n    Returns:\\n        (start_time, end_time)\\n        - 两者均为 None 表示无法解析任何时间信息\\n        - end_time 为 None 表示仅解析出单时间点（无范围）\\n    \\\\\\"\\\\\\"\\\\\\"\\n\\n# title_extractor.py\\ndef extract_title(text: str, time_text_removed: str) -> str:\\n    \\\\\\"\\\\\\"\\\\\\"\\n    从去除时间描述后的文本中提取事件标题。\\n\\n    Args:\\n        text: 原始输入文本（用于辅助判断）\\n        time_text_removed: 已移除时间描述的文本\\n\\n    Returns:\\n        事件标题字符串；无法提取时返回 \\\\\\"未命名事件\\\\\\"\\n    \\\\\\"\\\\\\"\\\\\\"\\n\\n# location_extractor.py\\ndef extract_location(text: str) -> str:\\n    \\\\\\"\\\\\\"\\\\\\"\\n    提取地点信息。\\n\\n    Returns:\\n        地点字符串；无法提取时返回 \\\\\\"\\\\\\"\\n    \\\\\\"\\\\\\"\\\\\\"\\n\\n# attendee_extractor.py\\ndef extract_attendees(text: str) -> list[str]:\\n    \\\\\\"\\\\\\"\\\\\\"\\n    提取参与人信息。\\n\\n    Returns:\\n        参与人名称列表；无法提取时返回 []\\n    \\\\\\"\\\\\\"\\\\\\"\\n\\\\`\\\\`\\\\`\\n\\n### 2.4 异常定义\\n\\n\\\\`\\\\`\\\\`python\\nclass ParseError(Exception):\\n    \\\\\\"\\\\\\"\\\\\\"日程解析内部错误，仅供子模块间流程控制使用，不对外抛出\\\\\\"\\\\\\"\\\\\\"\\n\\\\`\\\\`\\\\`\\n\\n---\\n\\n## 3. 实现要点\\n\\n### 3.1 技术方案选型\\n\\n**选型：规则引擎（正则 + 关键词匹配）**\\n\\n| 方案 | 优点 | 缺点 | 结论 |\\n|------|------|------|------|\\n| 规则引擎（正则） | 无第三方依赖、≤1秒天然满足、可控可调试可扩展 | 覆盖度有限、需持续维护模式库 | ✅ 采用 |\\n| 大模型 API | 覆盖度高、泛化能力强 | 网络延迟不可控（违反≤1秒）、依赖外部服务 | ❌ 不采用 |\\n| 第三方 NLP 库（如 LAC） | 中文分词能力强 | 引入第三方依赖、性能不确定 | ❌ 不采用 |\\n\\n### 3.2 核心处理流程\\n\\n\\\\`\\\\`\\\\`\\n输入 text\\n  │\\n  ├─ 1. 预处理：去除多余空白，统一中文标点（，→,）\\n  │\\n  ├─ 2. extract_time(text, base_date)\\n  │     ├─ 2a. 匹配相对日期关键词 → resolve_relative_date() 计算目标日期\\n  │     ├─ 2b. 匹配时间段模式（\\\\\\"X点到Y点\\\\\\"）→ start + end\\n  │     ├─ 2c. 匹配单时间点模式 → start, end=None\\n  │     ├─ 2d. 推断上午/下午：\\n  │     │     含\\\\\\"下午/晚上/傍晚\\\\\\" → 小时+12\\n  │     │     含\\\\\\"上午/早上/清晨\\\\\\" → 小时不变\\n  │     │     无关键词 + 小时≤6 → 默认下午(+12)\\n  │     │     无关键词 + 小时>6 → 默认上午(不变)\\n  │     └─ 2e. 若无日期关键词 → 使用 base_date 日期部分\\n  │\\n  ├─ 3. 从原文中移除已匹配的时间描述文本 → time_removed_text\\n  │\\n  ├─ 4. extract_location(text)\\n  │     ├─ 匹配 \\\\\\"地点在X\\\\\\" / \\\\\\"在X\\\\\\" 模式\\n  │     └─ 失败 → \\\\\\"\\\\\\"\\n  │\\n  ├─ 5. extract_attendees(text)\\n  │     ├─ 匹配 \\\\\\"和X\\\\\\" / \\\\\\"与X\\\\\\" 模式（X为人名关键词）\\n  │     └─ 失败 → []\\n  │\\n  ├─ 6. extract_title(text, time_removed_text)\\n  │     ├─ 从 time_removed_text 中移除地点和参与人描述\\n  │     ├─ 去除残余标点和空白\\n  │     ├─ 剩余文本作为标题\\n  │     └─ 若标题为空 → \\\\\\"未命名事件\\\\\\"\\n  │\\n  └─ 7. 组装返回 dict\\n       ├─ start_time/end_time → ISO 8601 格式化（带 +08:00 时区）\\n       ├─ end_time 为 None → start_time + timedelta(hours=1)\\n       ├─ start_time 为 None → start_time=\\\\\\"\\\\\\" , end_time=\\\\\\"\\\\\\"\\n       └─ location/attendees 直接填入\\n\\\\`\\\\`\\\\`\\n\\n### 3.3 关键正则模式定义（patterns.py）\\n\\n\\\\`\\\\`\\\\`python\\nimport re\\n\\n# ===== 相对日期模式 =====\\n# 每个条目为 (关键词, 预编译正则)\\nRELATIVE_DATE_PATTERNS: list[tuple[str, re.Pattern[str]]] = [\\n    (\\\\\\"明天\\\\\\",     re.compile(r\\\\\\"明天\\\\\\")),\\n    (\\\\\\"后天\\\\\\",     re.compile(r\\\\\\"后天\\\\\\")),\\n    (\\\\\\"今天\\\\\\",     re.compile(r\\\\\\"今天\\\\\\")),\\n    (\\\\\\"下周一\\\\\\",   re.compile(r\\\\\\"下周一\\\\\\")),\\n    (\\\\\\"下周二\\\\\\",   re.compile(r\\\\\\"下周二\\\\\\")),\\n    (\\\\\\"下周三\\\\\\",   re.compile(r\\\\\\"下周三\\\\\\")),\\n    (\\\\\\"下周四\\\\\\",   re.compile(r\\\\\\"下周四\\\\\\")),\\n    (\\\\\\"下周五\\\\\\",   re.compile(r\\\\\\"下周五\\\\\\")),\\n    (\\\\\\"下周六\\\\\\",   re.compile(r\\\\\\"下周六\\\\\\")),\\n    (\\\\\\"下周日\\\\\\",  .compile(r\\\\\\"下周日|下周天\\\\\\")),\\n    (\\\\\\"这个周五\\\\\\", re.compile(r\\\\\\"这个周五|这周五|本周五\\\\\\")),\\n    (\\\\\\"这个周一\\\\\\", re.compile(r\\\\\\"这个周一|这周一|本周一\\\\\\")),\\n    (\\\\\\"这个周二\\\\\\", re.compile(r\\\\\\"这个周二|这周二|本周二\\\\\\")),\\n    (\\\\\\"这个周三\\\\\\", re.compile(r\\\\\\"这个周三|这周三|本周三\\\\\\")),\\n    (\\\\\\"这个周四\\\\\\", re.compile(r\\\\\\"这个周四|这周四|本周四\\\\\\")),\\n    (\\\\\\"这个周六\\\\\\", re.compile(r\\\\\\"这个周六|这周六|本周六\\\\\\")),\\n    (\\\\\\"这个周日\\\\\\", re.compile(r\\\\\\"这个周日|这周日|本周日|这周天|本周天\\\\\\")),\\n]\\n\\n# ===== 时间段模式（优先匹配，避免被单时间点截断） =====\\nTIME_RANGE_PATTERN: re.Pattern[str] = re.compile(\\n    r\\\\\\"(上午|下午|晚上|傍晚)?(\\\\d{1,2})点(?:半)?(?:到|至|-|—)\\\\\\"\\n    r\\\\\\"(上午|下午|晚上|傍晚)?(\\\\d{1,2})点(?:半)?\\\\\\"\\n)\\n\\n# ===== 单时间点模式 =====\\nTIME_POINT_PATTERN: re.Pattern[str] = re.compile(\\n    r\\\\\\"(上午|下午|晚上|傍晚|早上|清晨)(\\\\d{1,2})点(?:半)?\\\\\\"\\n    r\\\\\\"|(\\\\d{1,2})点(?:半)?\\\\\\"\\n)\\n\\n# ===== 地点模式 =====\\nLOCATION_PATTERN: re.Pattern[str] = re.compile(\\n    r\\\\\\"地点在(.+?)(?:[，,。.]|$)\\\\\\"\\n    r\\\\\\"|在(.+?)(?:[，,。.]|$)\\\\\\"\\n)\\n\\n# ===== 参与人模式 =====\\nATTENDEE_PATTERN: re.Pattern[str] = re.compile(\\n    r\\\\\\"和(.+?)(?:[，,。.地点]|$)\\\\\\"\\n    r\\\\\\"|与(.+?)(?:[，,。.地点]|$)\\\\\\"\\n)\\n\\\\`\\\\`\\\\`\\n\\n### 3.4 相对时间计算核心逻辑\\n\\n\\\\`\\\\`\\\\`python\\nfrom datetime import datetime, timedelta\\nfrom zoneinfo import ZoneInfo\\n\\nSHANGHAI_TZ = ZoneInfo(\\\\\\"Asia/Shanghai\\\\\\")\\n\\nWEEKDAY_MAP: dict[str, int] = {\\n    \\\\\\"一\\\\\\": 0, \\\\\\"二\\\\\\": 1, \\\\\\"三\\\\\\": 2, \\\\\\"四\\\\\\": 3,\\n    \\\\\\"五\\\\\\": 4, \\\\\\"六\\\\\\": 5, \\\\\\"日\\\\\\": 6, \\\\\\"天\\\\\\": 6,\\n}\\n\\ndef resolve_relative_date(keyword: str, base_date: datetime) -> datetime:\\n    \\\\\\"\\\\\\"\\\\\\"根据相对日期关键词计算目标日期（保留 base_date 的时间部分）\\\\\\"\\\\\\"\\\\\\"\\n    if keyword == \\\\\\"今天\\\\\\":\\n        return base_date\\n    elif keyword == \\\\\\"明天\\\\\\":\\n        return base_date + timedelta(days=1)\\n    elif keyword == \\\\\\"后天\\\\\\":\\n        return base_date + timedelta(days=2)\\n    elif keyword.startswith(\\\\\\"下周\\\\\\"):\\n        # 下周X：先跳到下周一，再加 weekday 偏移\\n        target_weekday = WEEKDAY_MAP[keyword[2]]\\n        days_to_next_monday = (7 - base_date.weekday()) % 7 or 7\\n        days_ahead = days_to_next_monday + target_weekday\\n        return base_date + timedelta(days=days_ahead)\\n    elif keyword.startswith(\\\\\\"这个\\\\\\") or keyword.startswith(\\\\\\"这\\\\\\") or keyword.startswith(\\\\\\"本周\\\\\\"):\\n        # 本周X：计算本周目标星期几的日期\\n        suffix = keyword[-1]  # 取最后一个字符：一/二/.../日/天\\n        target_weekday = WEEKDAY_MAP[suffix]\\n        days_diff = target_weekday - base_date.weekday()\\n        if days_diff < 0:\\n            days_diff += 7  # 已过则取下周\\n        return base_date + timedelta(days=days_diff)\\n    else:\\n        raise ParseError(f\\\\\\"未知的相对日期关键词: {keyword}\\\\\\")\\n\\\\`\\\\`\\\\`\\n\\n### 3.5 时间推断策略\\n\\n| 场景 | 规则 | 示例 |\\n|------|------|------|\\n| 含\\\\\\"下午/晚上/傍晚\\\\\\" | 小时数 +12 | \\\\\\"下午3点\\\\\\" → 15:00 |\\n| 含\\\\\\"上午/早上/清晨\\\\\\" | 小时数不变 | \\\\\\"上午10点\\\\\\" → 10:00 |\\n| 无关键词 + 小时 ≤ 6 | 默认视为下午(+12) | \\\\\\"3点\\\\\\" → 15:00 |\\n| 无关键词 + 小时 > 6 | 默认视为上午(不变) | \\\\\\"10点\\\\\\" → 10:00 |\\n| 含\\\\\\"点半\\\\\\" | 分钟设为 30 | \\\\\\"下午3点半\\\\\\" → 15:30 |\\n\\n### 3.6 错误处理策略\\n\\n| 场景 | 处理方式 |\\n|------|---------|\\n| 时间无法解析 | \\\\`start_time=\\\\\\"\\\\\\"\\\\`, \\\\`end_time=\\\\\\"\\\\\\"\\\\` |\\n| 标题无法提取 | \\\\`title=\\\\\\"未命名事件\\\\\\"\\\\` |\\n| 地点无法提取 | \\\\`location=\\\\\\"\\\\\\"\\\\` |\\n| 参与人无法提取 | \\\\`attendees=[]\\\\` |\\n| 输入为空或纯空白 | 抛出 \\\\`ValueError\\\\` |\\n| 内部解析异常 | \\\\`ParseError\\\\` 仅用于子模块间流程控制，**不对外抛出** |\\n\\n### 3.7 性能考量\\n\\n- 所有操作为纯内存计算，无网络/IO，单次解析 ≤1秒 天然满足\\n- 正则预编译（\\\\`re.compile\\\\`）在模块加载时完成，运行时无编译开销\\n- 子模块按顺序调用，无并发需求\\n- 匹配顺序：时间段模式优先于单时间点模式，避免截断\\n\\n---\\n\\n## 4. 单元测试用例\\n\\n### 4.1 测试框架\\n\\n使用 \\\\`pytest\\\\`，测试文件位于 \\\\`tests/test_schedule_parser.py\\\\`。\\n\\n### 4.2 用例列表\\n\\n| 用例ID | 用例名称 | 输入 | base_date | 期望输出要点 | 类型 |\\n|--------|---------|------|-----------|-------------|------|\\n| UT-01 | 标准日程-相对时间+下午 | \\\\\\"明天下午3点开产品评审会\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"产品评审会\\\\\\", start=\\\\\\"2026-03-27T15:00:00+08:00\\\\\\", end=\\\\\\"2026-03-27T16:00:00+08:00\\\\\\", location=\\\\\\"\\\\\\", attendees=[] | 正常 |\\n| UT-02 | 标准日程-下周+地点+参与人 | \\\\\\"下周一上午10点和张总会面，地点在A栋302\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"和张总会面\\\\\\", start=\\\\\\"2026-03-30T10:00:00+08:00\\\\\\", end=\\\\\\"2026-03-30T11:00:00+08:00\\\\\\", location=\\\\\\"A栋302\\\\\\", attendees=[\\\\\\"张总\\\\\\"] | 正常 |\\n| UT-03 | 标准日程-时间范围 | \\\\\\"这个周五下午2点到4点代码评审\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"代码评审\\\\\\", start=\\\\\\"2026-03-27T14:00:00+08:00\\\\\\", end=\\\\\\"2026-03-27T16:00:00+08:00\\\\\\", location=\\\\\\"\\\\\\", attendees=[] | 正常 |\\n| UT-04 | 边界-仅时间无标题 | \\\\\\"明天下午3点\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"未命名事件\\\\\\", start=\\\\\\"2026-03-27T15:00:00+08:00\\\\\\", end=\\\\\\"2026-03-27T16:00:00+08:00\\\\\\" | 边界 |\\n| UT-05 | 边界-无时间描述 | \\\\\\"和张总开会\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"和张总开会\\\\\\", start=\\\\\\"\\\\\\", end=\\\\\\"\\\\\\", attendees=[\\\\\\"张总\\\\\\"] | 边界 |\\n| UT-06 | 边界-跨上午下午时间段 | \\\\\\"上午9点到下午5点全员大会\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"全员大会\\\\\\", start=\\\\\\"2026-03-26T09:00:00+08:00\\\\\\", end=\\\\\\"2026-03-26T17:00:00+08:00\\\\\\" | 边界 |\\n| UT-07 | 异常-空字符串输入 | \\\\\\"\\\\\\" | 任意 | 抛出 ValueError | 异常 |\\n| UT-08 | 异常-纯空白输入 | \\\\\\"   \\\\\\" | 任意 | 抛出 ValueError | 异常 |\\n| UT-09 | 正常-后天+晚上 | \\\\\\"后天晚上8点团建聚餐\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"团建聚餐\\\\\\", start=\\\\\\"2026-03-28T20:00:00+08:00\\\\\\", end=\\\\\\"2026-03-28T21:00:00+08:00\\\\\\" | 正常 |\\n| UT-10 | 边界-无日期默认今天 | \\\\\\"下午2点站会\\\\\\" | 2026-03-26 09:00(周四) | title=\\\\\\"站会\\\\\\", start=\\\\\\"2026-03-26T14:00:00+08:00\\\\\\", end=\\\\\\"2026-03-26T15:00:00+08:00\\\\\\" | 边界 |\\n\\n### 4.3 测试代码骨架\\n\\n\\\\`\\\\`\\\\`python\\nimport pytest\\nfrom datetime import datetime\\nfrom zoneinfo import ZoneInfo\\nfrom schedule_parser import parse_schedule\\n\\nSHANGHAI_TZ = ZoneInfo(\\\\\\"Asia/Shanghai\\\\\\")\\n\\n# 固定基准日期：2026-03-26 09:00（周四）\\nBASE = datetime(2026, 3, 26, 9, 0, tzinfo=SHANGHAI_TZ)\\n\\n\\nclass TestParseSchedule:\\n    \\\\\\"\\\\\\"\\\\\\"自然语言日程解析模块单元测试\\\\\\"\\\\\\"\\\\\\"\\n\\n    # ===== 正常路径 =====\\n\\n    def test_ut01_standard_relative_afternoon(self):\\n        \\\\\\"\\\\\\"\\\\\\"标准日程：相对时间+下午\\\\\\"\\\\\\"\\\\\\"\\n        result = parse_schedule(\\\\\\"明天下午3点开产品评审会\\\\\\", BASE)\\n        assert result[\\\\\\"title\\\\\\"] == \\\\\\"产品评审会\\\\\\"\\n        assert result[\\\\\\"start_time\\\\\\"] == \\\\\\"2026-03-27T15:00:00+08:00\\\\\\"\\n        assert result[\\\\\\"end_time\\\\\\"] == \\\\\\"2026-03-27T16:00:00+08:00\\\\\\"\\n        assert result[\\\\\\"location\\\\\\"] == \\\\\\"\\\\\\"\\n        assert result[\\\\\\"attendees\\\\\\"] == []\\n\\n    def test_ut02_standard_nextweek_location_attendee(self):\\n        \\\\\\"\\\\\\"\\\\\\"标准日程：下周+地点+参与人\\\\\\"\\\\\\"\\\\\\"\\n        result = parse_schedule(\\\\\