│  相对时间计算核心逻辑\n\n\\`\\`\\`python\nfrom datetime import datetime,     │
│  timedelta\nfrom zoneinfo import ZoneInfo\n\nSHANGHAI_TZ =                   │
│  ZoneInfo(\\"Asia/Shanghai\\")\n\nWEEKDAY_MAP: dict[str, int] = {\n          │
