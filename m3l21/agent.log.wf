tor', 'title': 'Selector'}, 'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to fill', 'title': 'Index'}, 'value': {'description': 'Value to fill', 'title': 'Value', 'type': 'string'}, 'clear': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': 'Whether to clear existing text before filling', 'title': 'Clear'}}, 'required': ['selector', 'index', 'value', 'clear'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_markdown', 'description': 'Get the markdown content of the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_text', 'description': 'Get the text content of the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_read_links', 'description': 'Get all links on the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_new_tab', 'description': 'Open a new tab', 'parameters': {'properties': {'url': {'description': 'URL to open in the new tab', 'title': 'Url', 'type': 'string'}}, 'required': ['url'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_tab_list', 'description': 'Get the list of tabs', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_switch_tab', 'description': 'Switch to a specific tab', 'parameters': {'properties': {'index': {'description': 'Tab index to switch