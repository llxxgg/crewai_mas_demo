    "content": "{\n  \"action\": \"read\",\n  \"path\": \"/mnt/skills/load_skills.yaml\",\n  \"content\": \"# Skill 清单：m2l16 Skills 生态课程演示\\n#\\n# type 字段区分 Skill 的执行方式：\\n#   task      → 触发独立 Sub-Crew 在 AIO-Sandbox 中执行（需要代码运行）\\n#   reference → 直接注入指令到调用方上下文，不启动 Sub-Crew（只读规范类）\\n#\\n# 💡 核心点：type 写在这里，不改 Anthropic 官方 SKILL.md 文件\\n\\nskills:\\n  - name: pdf\\n    path: ./pdf\\n    type: task       # 需要代码执行（pypdf / pdfplumber）\\n    enabled: true\\n\\n  - name: docx\\n    path: ./docx\\n    type: task       # 需要代码执行（docx-js / pandoc）\\n    enabled: true\\n\\n  # m3l20：文件系统记忆 Skills\\n  - name: memory-save\\n    path: ./memory-save\\n    type: task       # 写入 workspace/ 文件，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  - name: skill-creator\\n    path: ./skill-creator\\n    type: task       # 写入 skills/ 目录，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  - name: memory-governance\\n    path: ./memory-governance\\n    type: task       # 扫描 + 报告 + 清理，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  # 预留：参考型 Skill 示例（如品牌规范、代码规范等）\\n  # - name: brand-guidelines\\n  #   path: ./brand-guidelines\\n  #   type: reference   # 只读指令，不执行脚本\\n  #   enabled: false\\n\\n  # HK Stock Analysis Skill\\n  - name: analyze-hk-stock\\n    path: ./analyze-hk-stock\\n    type: task\\n    enabled: true\\n\",\n  \"success\": true\n}"
