l * screen_height * height_factor) / height_factor where x_model, y_model are normalized model output coordinates (0-1), screen_width/height are screen dimensions, width_factor/height_factor are quantization factors, If the factors are unknown, leave it blank. Most models do not require this parameter.', 'title': 'Factors'}, 'x': {'description': 'X pixel coordinate', 'title': 'X', 'type': 'number'}, 'y': {'description': 'Y pixel coordinate', 'title': 'Y', 'type': 'number'}}, 'required': ['factors', 'x', 'y'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_download_list', 'description': 'Get the list of downloaded files', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_screenshot', 'description': 'Take a screenshot of the current page or a specific element', 'parameters': {'properties': {'name': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'Name for the screenshot', 'title': 'Name'}, 'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for element to screenshot', 'title': 'Selector'}, 'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'index of the element to screenshot', 'title': 'Index'}, 'width': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Width in pixels (default: viewport width)', 'title': 'Width'}, 'height': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Height in pixels (default: viewport height)', 'title': 'Height'}, 'fullPage': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': 'Full page screenshot (default: false)', 'title': 'Fullpage'}, 'highlight': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': 'Highlight the element', 'title': 'Highlight'}}, 'type': 'object', 'additionalProperties': False, 'required': ['name', 'selector', 'index', 'width', 'height', 'fullPage', 'highlight']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_click', 'description': 'Click an element on the page, before using the tool, use `browser_get_clickable_elements` to get the index of the element, but not call `browser_get_clickable_elements` multiple times', 'parameters': {'properties': {'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to click', 'title': 'Index'}}, 'type': 'object', 'additionalProperties': False, 'required': ['index']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_select', 'description': "Select an element on the page with index, Either 'index' or 'selector' must be provided", 'parameters': {'properties': {'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to select', 'title': 'Index'}, 'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for element to select', 'title': 'Selector'}, 'value': {'description': 'Value to select', 'title': 'Value', 'type': 'string'}}, 'required': ['index', 'selector', 'value'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_hover', 'description': "Hover an element on the page, Either 'index' or 'selector' must be provided", 'parameters': {'properties': {'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to hover', 'title': 'Index'}, 'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for element to hover', 'title': 'Selector'}}, 'type': 'object', 'additionalProperties': False, 'required': ['index', 'selector']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_clickable_elements', 'description': "Get the clickable or hoverable or selectable elements on the current page, don't call this tool multiple times", 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_scroll', 'description': 'Scroll the page', 'parameters': {'properties': {'amount': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Pixels to scroll (positive for down, negative for up), if the amount is not provided, scroll to the bottom of the page', 'title': 'Amount'}}, 'type': 'object', 'additionalProperties': False, 'required': ['amount']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_close', 'description': 'Close the browser when the task is done and the browser is not needed anymore', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_press_key', 'description': 'Press a key on the keyboard', 'parameters': {'properties': {'key': {'description': 'Name of the key to press or a character to generate, such as Enter, Tab, Escape, Backspace, Delete, Insert, F1, F2, F3, F4, F5, F6, F7, F8, F9, F10, F11, F12, ArrowLeft, ArrowRight, ArrowUp, ArrowDown, PageUp, PageDown, Home, End, ShiftLeft, ShiftRight, ControlLeft, ControlRight, AltLeft, AltRight, MetaLeft, MetaRight, CapsLock, PrintScreen, ScrollLock, Pause, ContextMenu', 'title': 'Key', 'type': 'string'}}, 'required': ['key'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}]} payload=[{'role': 'system', 'content': 'You are SKILL-CREATOR Skill 执行专家. 你是一位专精于 skill-creator 文件处理的 AI 专家。\n你掌握以下操作规范，请严格遵循：\n\n\n# Skill Creator\n\nA skill for capturing workflows and turning them into reusable skills.\n\nThe process: understand what the user wants → draft a quality SKILL.md → save it to the sandbox → register it so future sessions can use it.\n\n## Creating a skill\n\n### Capture Intent\n\nStart by understanding the user\'s intent. The current conversation might already contain a workflow the user wants to capture (e.g., they say "turn this into a skill"). If so, extract answers from the conversation history first — the tools used, the sequence of steps, corrections the user made, input/output formats observed. The user may need to fill the gaps, and should confirm before proceeding.\n\n1. What should this skill enable the assistant to do?\n2. When should this skill trigger? (what user phrases/contexts)\n3. What\'s the expected output format?\n\n### Interview and Research\n\nProactively ask questions about edge cases, input/output formats, success criteria, and dependencies. Come prepared with context to reduce burden on the user.\n\n### Write the SKILL.md\n\nBased on the user interview, fill in these components:\n\n- **name**: Skill identifier (kebab-case, e.g. `analyze-hk-stock`)\n- **description**: When to trigger, what it does. This is the primary triggering mechanism — include both what the skill does AND specific contexts for when to use it. Note: Claude has a tendency to "undertrigger" skills — to not use them when they\'d be useful. To combat this, make the description a little "pushy". Instead of "A skill for analyzing stocks", write "Use this skill when the user asks to analyze Hong Kong stocks, research HK companies, or evaluate HK investment opportunities. Activate whenever 港股 or HK stock analysis is needed."\n- **allowed-tools**: Minimal list — only tools actually needed\n- **the skill body**\n\n### Tool constraints（项目特定，必须遵守）\n\n- 你**只能**使用 AIO-Sandbox 提供的基础工具（即本 Skill 声明中的 `Read` / `Write` / `Bash` / `Browser`）。  \n  - 不允许在 `allowed-tools` 里发明新的“业务工具名”（例如 `get_hk_stock_price`、`search_news`、`generate_report` 这类项目里并不存在的工具），否则主 Agent 无法真正调用这些能力。\n  - 如果不确定某个工具名是否真实存在，就**不要**写进 `allowed-tools`，宁可只使用基础文件 / 命令 / 浏览器工具组合完成任务。\n- 业务逻辑和复杂流程（如“用 akshare 拉取行情并计算指标”“批量处理表格”）应通过**代码脚本**实现，而不是伪造一个看似专业的工具名：\n  - 将实现代码沉淀到 `scripts/*.py` 或 `scripts/*.js` / `scripts/*.ts` 中，由 AIO-Sandbox 通过 `Bash` / 相关执行器调用。\n  - 在 SKILL.md 正文中，用自然语言说明脚本的用法，例如：\n    - “在 AIO-Sandbox 中运行 `python scripts/analyze_hk_stock.py --symbol 0700.HK`，该脚本内部使用 akshare 获取行情和技术指标，并将结果输出为 JSON。”\n  - 不要把脚本名字写入 `allowed-tools`，因为脚本是通过 Bash / 运行时调用的实现细节，不是独立的 MCP 工具。\n- 当你**不会写代码、或不确定如何使用某个三方库 / API** 时：\n  - 优先使用 `Browser` 类浏览器工具进行调研，查官方文档、示例代码和最佳实践；\n  - 调研完成后，再回到“脚本 + 基础工具”的模式，把可复用的调用方式沉淀到 `scripts/` 并在 SKILL.md 中记录清楚。\n\n#### Anatomy of a Skill\n\n```\nskill-name/\n├── SKILL.md (required)\n│   ├── YAML frontmatter (name, description required)\n│   └── Markdown instructions\n└── Bundled Resources (optional)\n    ├── scripts/    - Executable code for deterministic/repetitive tasks\n    ├── references/ - Docs loaded into context as needed\n    └── assets/     - Files used in output (templates, icons, fonts)\n```\n\n#### Progressive Disclosure\n\nSkills use a three-level loading system:\n1. **Metadata** (name + description) - Always in context (~100 words)\n2. **SKILL.md body** - In context whenever skill triggers (<500 lines ideal)\n3. **Bundled resources** - As needed (unlimited)\n\nKeep SKILL.md under 500 lines. If approaching the limit, add a layer of hierarchy with pointers to reference files.\n\n#### Writing Style\n\nExplain to the model *why* things are important rather than stacking MUST/NEVER. Use theory of mind — make the skill general, not narrow to specific examples. If you find yourself writing ALWAYS or NEVER in all caps, that\'s a yellow flag: reframe and explain the reasoning instead. A model that understands *why* will handle edge cases correctly; one that just follows rules will fail on anything unexpected.\n\n**Examples pattern:**\n```markdown\n## Commit message format\n**Example:**\nInput: Added user authentication with JWT tokens\nOutput: feat(auth): implement JWT-based authentication\n```\n\n**Output format pattern:**\n```markdown\n## Report structure\nUse this template:\n# [Title]\n## Executive summary\n## Key findings\n## Recommendations\n```\n\n---\n\n## Saving to the sandbox (project-specific)\n\nThis skill runs as a Sub-Crew inside AIO-Sandbox. All file operations go through MCP tools — do not write to the local filesystem directly.\n\n### Step 1: Check for existing skill\n\nRead `/mnt/skills/load_skills.yaml` to check if a skill with the same name already exists.\n\nIf it exists: ask the user — overwrite / create as `-v2` / cancel.\nReason: silent overwrite would destroy the user\'s existing SOP with no way to recover.\n\n### Step 2: Write SKILL.md\n\n```\nmkdir /mnt/skills/<skill-name>/\nwrite /mnt/skills/<skill-name>/SKILL.md  ← the drafted content\n```\n\n### Step 3: Register in load_skills.yaml\n\nRead the current `/mnt/skills/load_skills.yaml`, then append:\n\n```yaml\n  - name: <skill-name>\n    path: ./<skill-name>\n    type: task        # spawns Sub-Crew in AIO-Sandbox\n    enabled: true\n```\n\nWrite the updated file back.\n\n### Step 4: Verify\n\nRead `/mnt/skills/<skill-name>/SKILL.md` and `/mnt/skills/load_skills.yaml` to confirm both files are written correctly and the YAML is valid.\n\nReason: file writes via MCP don\'t throw exceptions on failure — read-back verification is the only reliable confirmation.\n\n### Step 5: Return result\n\n```json\n{\n  "errcode": 0,\n  "errmsg": "success",\n  "skill_name": "<skill-name>",\n  "path": "/mnt/skills/<skill-name>/SKILL.md",\n  "trigger": "one-line summary of when this skill activates"\n}\n```\n\n\n<sandbox_execution_directive>\nIMPORTANT:【强制约束】所有脚本和文件操作必须在 AIO-Sandbox 中执行，禁止直接操作本地文件系统。\n此 Skill 资源已挂载至沙盒绝对路径：/mnt/skills/skill-creator/\n\n可用沙盒工具及正确用法：\n1. sandbox_execute_bash：执行 Shell 命令。参数：cmd（必填，字符串）、cwd（可选，工作目录绝对路径）、timeout（可选，秒）。\n   - 运行脚本示例：如需运行脚本scripts/xxx.py，则调用sandbox_execute_bash且参数为cmd="python /mnt/skills/skill-creator/scripts/xxx.py 参数"，如需可设 cwd="/mnt/skills/skill-creator"。\n   - 安装依赖：cmd="pip install 包名"，再重试任务。\n2. sandbox_file_operations：统一文件操作。参数：action（必填，\'read\'|\'write\'|\'list\'|\'find\'|\'replace\'|\'search\'）、path（必填，文件或目录绝对路径）、其余见工具说明。\n   - 读取单个文件：action="read", path="文件绝对路径"（示例：如需要获取reference/xxx.md，则调用工具sandbox_file_operations且参数为action="read", path="/mnt/skills/skill-creator/reference/xxx.md"）。\n   - 列出目录：action="list", path="目录绝对路径"（如 path="/mnt/skills/skill-creator/reference"），可选 recursive=true。\n   - 按模式查找文件：action="find", path="目录", pattern="*.md"。\n3. sandbox_str_replace_editor：编辑文件。参数：command（\'view\'|\'create\'|\'str_replace\'|\'insert\'）、path（文件路径）等。\n4. sandbox_execute_code：执行代码片段。参数：code（必填）、language（\'python\'|\'javascript\'）、timeout（可选）。\n</sandbox_execution_directive>\nYour personal goal is: 严格按照 skill-creator Skill 的操作规范，在 AIO-Sandbox 中完成任务'}, {'role': 'user', 'content': '\nCurrent Task: 根据以下任务要求，使用你掌握的 Skill 操作规范完成任务。\n\n任务要求：\n{"skill_name": "analyze-hk-stock", "description": "分析港股的标准操作流程(SOP)，包含三个步骤：1. 查询实时行情 2. 查看近期新闻 3. 编写估值分析", "steps": ["查询指定港股的实时行情数据", "搜索该股票近一个月的相关新闻", "基于行情和新闻编写估值分析报告"], "output_file": "/workspace/output/analyze-hk-stock.yaml"}\n\n执行要求：\n1. 所有的操作必须在沙盒中执行，不得操作本地文件系统。\n   当前已挂载的目录：\n   - ./workspace:/workspace:rw（可读写，memory-save 写记忆文件到这里）\n   - ../skills:/mnt/skills:rw（可读写，skill-creator 写 SKILL.md 到这里）\n\n2. 记忆文件读写规范：\n   - 读取：用沙盒绝对路径 /workspace/<filename>（如 /workspace/user.md）\n   - 写入：同上，写前必须先 read 目标文件，确认无重复内容\n\n3. Skill 文件写入规范：\n   - 目录：/mnt/skills/<skill-name>/SKILL.md\n   - 注册：同时更新 /mnt/skills/load_skills.yaml\n\n4. 如遇依赖缺失，先在沙盒中安装再继续\n\nThis is the expected criteria for your final answer: 一份结构化的任务执行结果，按照任务要求中的json schema输出。\nyou MUST return the actual complete content as the final answer, not a summary.'}, {'role': 'assistant', 'content': None, 'tool_calls': [{'id': 'call_7638f492b3cc4372a6ac1e09', 'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_file_operations', 'arguments': '{"action": "read", "path": "/mnt/skills/load_skills.yaml"}'}}]}, {'role': 'tool', 'tool_call_id': 'call_7638f492b3cc4372a6ac1e09', 'name': 'localhost_8022_mcp_sandbox_file_operations', 'content': '{\n  "action": "read",\n  "path": "/mnt/skills/load_skills.yaml",\n  "content": "# Skill 清单：m2l16 Skills 生态课程演示\\n#\\n# type 字段区分 Skill 的执行方式：\\n#   task      → 触发独立 Sub-Crew 在 AIO-Sandbox 中执行（需要代码运行）\\n#   reference → 直接注入指令到调用方上下文，不启动 Sub-Crew（只读规范类）\\n#\\n# 💡 核心点：type 写在这里，不改 Anthropic 官方 SKILL.md 文件\\n\\nskills:\\n  - name: pdf\\n    path: ./pdf\\n    type: task       # 需要代码执行（pypdf / pdfplumber）\\n    enabled: true\\n\\n  - name: docx\\n    path: ./docx\\n    type: task       # 需要代码执行（docx-js / pandoc）\\n    enabled: true\\n\\n  # m3l20：文件系统记忆 Skills\\n  - name: memory-save\\n    path: ./memory-save\\n    type: task       # 写入 workspace/ 文件，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  - name: skill-creator\\n    path: ./skill-creator\\n    type: task       # 写入 skills/ 目录，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  - name: memory-governance\\n    path: ./memory-governance\\n    type: task       # 扫描 + 报告 + 清理，需要沙盒 MCP 执行\\n    enabled: true\\n\\n  # 预留：参考型 Skill 示例（如品牌规范、代码规范等）\\n  # - name: brand-guidelines\\n  #   path: ./brand-guidelines\\n  #   type: reference   # 只读指令，不执行脚本\\n  #   enabled: false\\n",\n  "success": true\n}'}, {'role': 'user', 'content': 'Analyze the tool result. If requirements are met, provide the Final Answer. Otherwise, call the next tool. Deliver only the answer without meta-commentary.'}, {'role': 'assistant', 'content': None, 'tool_calls': [{'id': 'call_b567c9300b8144799e5c7ff2', 'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_file_operations', 'arguments': '{"action": "list", "path": "/mnt/skills"}'}}]}, {'role': 'tool', 'tool_call_id': 'call_b567c9300b8144799e5c7ff2', 'name': 'localhost_8022_mcp_sandbox_file_operations', 'content': '{\n  "action": "list",\n  "path": "/mnt/skills",\n  "files": [\n    {\n      "name": "algorithmic-art",\n      "path": "/mnt/skills/algorithmic-art",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1773636103",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "docx",\n      "path": "/mnt/skills/docx",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1772458050",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "load_skills.yaml",\n      "path": "/mnt/skills/load_skills.yaml",\n      "is_directory": false,\n      "size": 1287,\n      "modified_time": "1773742110",\n      "permissions": null,\n      "extension": ".yaml"\n    },\n    {\n      "name": "memory-governance",\n      "path": "/mnt/skills/memory-governance",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1773736236",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "memory-save",\n      "path": "/mnt/skills/memory-save",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1773736236",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "pdf",\n      "path": "/mnt/skills/pdf",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1772458050",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "pptx",\n      "path": "/mnt/skills/pptx",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1772458050",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "skill-creator",\n      "path": "/mnt/skills/skill-creator",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1773739748",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "xlsx",\n      "path": "/mnt/skills/xlsx",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1772458050",\n      "permissions": null,\n   