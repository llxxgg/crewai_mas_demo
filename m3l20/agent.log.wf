'properties': {'command': {'description': '', 'title': 'Command', 'type': 'string'}, 'path': {'description': '', 'title': 'Path', 'type': 'string'}, 'file_text': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'File Text'}, 'old_str': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Old Str'}, 'new_str': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'New Str'}, 'insert_line': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Insert Line'}, 'view_range': {'anyOf': [{}, {'items': {}, 'type': 'array'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'View Range'}}, 'required': ['command', 'path', 'file_text', 'old_str', 'new_str', 'insert_line', 'view_range'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_get_context', 'description': "Get sandbox environment information. aio system's version.\n\n    Returns:\n        Dict containing aio sandbox's environment info, version, and home directory", 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_get_packages', 'description': "Get installed packages by language.\n\n    Args:\n        language: Optional language filter ('python' or 'nodejs')\n\n    Returns: String listing installed packages", 'parameters': {'properties': {'language': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Language'}}, 'type': 'object', 'additionalProperties': False, 'required': ['language']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_execute_bash', 'description': "Execute a shell command. Sessions are managed automatically.\n\n  