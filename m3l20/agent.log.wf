 'default': None, 'description': '', 'title': 'New Session'}, 'timeout': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Timeout'}}, 'required': ['cmd', 'cwd', 'new_session', 'timeout'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_convert_to_markdown', 'description': 'Convert a resource described by an http:, https:, file: or data: URI to markdown', 'parameters': {'properties': {'uri': {'description': '', 'title': 'Uri', 'type': 'string'}}, 'required': ['uri'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_navigate', 'description': 'Navigate to a URL', 'parameters': {'properties': {'url': {'description': '', 'title': 'Url', 'type': 'string'}}, 'required': ['url'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_go_back', 'description': 'Go back to the previous page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_go_forward', 'description': 'Go forward to the next page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_form_input_fill', 'description': "Fill out an input field, before using the tool, Either 'index' or 'selector' must be provided", 'parameters': {'properties': {'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for input field, priority use index, if index is not provided, use selector', 'title': 'Selector'}, 'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to fill', '