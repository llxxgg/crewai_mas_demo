_directory": false,\n      "size": 171367,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml.xsd",\n      "path": "/mnt/skills/docx/scripts/office/schemas/ISO-IEC29500-4_2016/wml.xsd",\n      "is_directory": false,\n      "size": 171367,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "xlsx",\n      "path": "/mnt/skills/xlsx",\n      "is_directory": true,\n      "size": null,\n      "modified_time": "1772458050",\n      "permissions": null,\n      "extension": null\n    },\n    {\n      "name": "xml.xsd",\n      "path": "/mnt/skills/xlsx/scripts/office/schemas/ISO-IEC29500-4_2016/xml.xsd",\n      "is_directory": false,\n      "size": 4646,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "xml.xsd",\n      "path": "/mnt/skills/pptx/scripts/office/schemas/ISO-IEC29500-4_2016/xml.xsd",\n      "is_directory": false,\n      "size": 4646,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "xml.xsd",\n      "path": "/mnt/skills/docx/scripts/office/schemas/ISO-IEC29500-4_2016/xml.xsd",\n      "is_directory": false,\n      "size": 4646,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    }\n  ],\n  "total_count": 259,\n  "directory_count": 47,\n  "file_count": 212,\n  "success": true\n}'}, {'role': 'user', 'content': 'Analyze the tool result. If requirements are met, provide the Final Answer. Otherwise, call the next tool. Deliver only the answer without meta-commentary.'}, {'role': 'assistant', 'content': None, 'tool_calls': [{'id': 'call_23df4a1104254274ac24d448', 'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_file_operations', 'arguments': '{"action": "read", "path": "/mnt/skills/analyze-hk-stock/SKILL.md"}'}}]}, {'role': 'tool', 'tool_call_id': 'call_23df4a1104254274ac24d448', 'name': 'localhost_8022_mcp_sandbox_file_operations', 'content': '{\n  "action": "read",\n  "path": "/mnt/skills/analyze-hk-stock/SKILL.md",\n  "content": "---\\nname: analyze-hk-stock\\ndescription: Use this skill when the user asks to analyze Hong Kong stocks, research HK companies, or evaluate HK investment opportunities. Activate whenever 港股 or HK stock analysis is needed.\\n---\\n\\n## Overview\\nThis skill provides a standardized workflow for analyzing Hong Kong-listed stocks. It follows a three-step process: gathering real-time market data, collecting recent news coverage, and synthesizing a valuation analysis report.\\n\\n## Workflow Steps\\n\\n### Step 1: Query Real-time Market Data\\n- Use browser tools to navigate to financial websites (like Yahoo Finance, Bloomberg, or HKEX) to retrieve current stock price, trading volume, market cap, and key metrics for the specified HK stock ticker.\\n- Ensure the data includes at least: current price, daily change %, 52-week range, P/E ratio, and dividend yield.\\n\\n### Step 2: Search Recent News\\n- Use browser tools to search for news articles about the specific stock from the past month.\\n- Focus on credible financial news sources and official company announcements.\\n- Collect headlines, publication dates, and brief summaries of relevant news items.\\n\\n### Step 3: Generate Valuation Analysis Report\\n- Synthesize the market data and news findings into a structured valuation analysis.\\n- The report should include:\\n  - Current market position\\n  - Recent developments (from news)\\n  - Key valuation metrics interpretation\\n  - Risk factors identified\\n  - Investment outlook summary\\n\\n## Output Format\\nThe final output should be a comprehensive markdown report with the following structure:\\n\\n# [Stock Name] ([Ticker]) - HK Stock Analysis\\n\\n## Executive Summary\\nBrief overview of current status and investment thesis.\\n\\n## Market Data\\n- Current Price: [price]\\n- Daily Change: [change %]\\n- Market Cap: [market cap]\\n- P/E Ratio: [P/E]\\n- Dividend Yield: [yield %]\\n- 52-Week Range: [low] - [high]\\n\\n## Recent News Summary\\n- [Date] - [Headline]: [Brief summary]\\n- [Date] - [Headline]: [Brief summary]\\n(Include 3-5 most relevant recent news items)\\n\\n## Valuation Analysis\\nDetailed analysis combining market data and news context.\\n\\n## Risk Factors\\nKey risks identified from market conditions and news.\\n\\n## Investment Outlook\\nShort-term and long-term outlook assessment.\\n\\n## Allowed Tools\\nThis skill requires access to web browsing capabilities to gather real-time financial data and news. The implementation uses browser navigation and content extraction rather than direct API calls to ensure data freshness and availability across different financial platforms.",\n  "success": true\n}'}, {'role': 'user', 'content': 'Analyze the tool result. If requirements are met, provide the Final Answer. Otherwise, call the next tool. Deliver only the answer without meta-commentary.'}, {'role': 'assistant', 'content': None, 'tool_calls': [{'id': 'call_71e6fd3ab626438299953ce8', 'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_file_operations', 'arguments': '{"action": "read", "path": "/mnt/skills/memory-governance/SKILL.md"}'}}]}, {'role': 'tool', 'tool_call_id': 'call_71e6fd3ab626438299953ce8', 'name': 'localhost_8022_mcp_sandbox_file_operations', 'content': '{\n  "action": "read",\n  "path": "/mnt/skills/memory-governance/SKILL.md",\n  "content": "---\\nname: memory-governance\\ndescription: >\\n  Use this skill to audit and clean up workspace memory files and the skills\\n  directory. Activate when:\\n  - memory.md is approaching 150+ lines (Bootstrap limit is 200)\\n  - User requests a memory cleanup or audit\\n  - Skills directory has grown large and may contain duplicates or stale entries\\n  - memory-save reports that memory.md is near the limit\\n\\n  Do NOT activate for: normal conversation, saving new memories (use\\n  memory-save), creating new skills (use skill-creator).\\nallowed-tools:\\n  - Read\\n  - Write\\n  - Bash\\n---\\n\\n# memory-governance：记忆与 Skill 治理\\n\\n## 概述\\n\\n定期审计 workspace 记忆文件和 skills/ 目录，输出结构化分析报告，\\n用户确认后执行清理操作，防止记忆腐化和技能目录膨胀。\\n\\n执行频率：每月一次，或 memory-save 检测到 memory.md 超过 180 行时主动触发。\\n\\n**为什么需要治理：**\\n混乱的长记忆是整个应用的杀手。记忆腐化有两条路径：\\n1. **信息过时**：user.md 有旧偏好、memory.md 有死链（指向已删除文件）\\n2. **索引爆炸**：memory.md 不断追加接近 200 行、skills/ 有重复功能的 Skill\\n\\n## 步骤\\n\\n### 第一步：扫描，生成 JSON 分析报告\\n\\n读取以下文件，进行结构化分析：\\n- `/workspace/memory.md`：检查行数、死链（索引条目对应文件不存在）\\n- `/workspace/*.md`：检查 topic 文件的最后修改时间\\n- `/mnt/skills/load_skills.yaml`：检查已注册 Skill 列表\\n- `/mnt/skills/*/SKILL.md`：检查 description 是否有重叠\\n\\n生成内部 JSON 分析（精确，便于后续操作）：\\n\\n```json\\n{\\n  \\"memory_issues\\": [\\n    {\\n      \\"type\\": \\"dead_link\\",\\n      \\"entry\\": \\"投资记录 → memory_invest.md\\",\\n      \\"reason\\": \\"文件不存在\\"\\n    },\\n    {\\n      \\"type\\": \\"near_limit\\",\\n      \\"current_lines\\": 178,\\n      \\"limit\\": 200,\\n      \\"action\\": \\"trigger_governance\\"\\n    }\\n  ],\\n  \\"topic_files\\": [\\n    {\\n      \\"file\\": \\"memory_2023_project.md\\",\\n      \\"last_modified\\": \\"2023-11-01\\",\\n      \\"days_since\\": 480,\\n      \\"action\\": \\"archive\\"\\n    }\\n  ],\\n  \\"skill_issues\\": [\\n    {\\n      \\"type\\": \\"duplicate\\",\\n      \\"skills\\": [\\"analyze-stock\\", \\"hk-stock-analysis\\"],\\n      \\"recommendation\\": \\"merge into analyze-hk-stock\\"\\n    }\\n  ]\\n}\\n```\\n\\n### 第二步：生成 MD 治理报告（给用户审批）\\n\\n将 JSON 分析转换为可读 Markdown，写入 `/workspace/memory_governance_report.md`：\\n\\n```markdown\\n# 记忆治理报告 — <日期>\\n\\n## memory.md 状态\\n- 当前行数：<n> 行（上限 200 行）\\n- 状态：<正常 / 警告 / 已超限>\\n\\n## 发现的问题\\n\\n### 死链（共 <n> 条）\\n| 条目 | 原因 | 建议操作 |\\n|------|------|---------|\\n| 投资记录 → memory_invest.md | 文件不存在 | 删除此条目 |\\n\\n### 过期 Topic 文件（<n> 个）\\n| 文件 | 最后更新 | 建议操作 |\\n|------|---------|---------|\\n| memory_2023_project.md | 480 天前 | 归档或删除 |\\n\\n### Skill 重叠（<n> 组）\\n| Skill 1 | Skill 2 | 建议 |\\n|---------|---------|------|\\n| analyze-stock | hk-stock-analysis | 合并为 analyze-hk-stock |\\n\\n## 建议操作清单\\n- [ ] 删除 memory.md 中 <n> 条死链\\n- [ ] 归档 <n> 个过期 topic 文件到 /workspace/archive/\\n- [ ] 合并重叠 Skill\\n```\\n\\n### 第三步：等待用户确认，再执行清理\\n\\n**CRITICAL：不得在用户确认前执行任何删除或修改操作**\\n原因：治理报告可能误判（如文件确实存在但路径格式不同），用户确认是最后防线。\\n报告生成后，明确提示用户：\\"请确认以上操作清单，回复\'确认执行\'后我将开始清理。\\"\\n\\n用户确认后，按清单逐项执行：\\n1. 从 memory.md 删除死链条目\\n2. 将过期 topic 文件移动到 `/workspace/archive/`（不删除，保留历史）\\n3. 按用户指示合并或禁用重叠 Skill\\n\\n**CRITICAL：执行后读取验证**\\n每项操作后读取对应文件，确认变更已落盘、无误删。\\n",\n  "success": true\n}'}, {'role': 'user', 'content': 'Analyze the tool result. If requirements are met, provide the Final Answer. Otherwise, call the next tool. Deliver only the answer without meta-commentary.'}, {'role': 'assistant', 'content': None, 'tool_calls': [{'id': 'call_1dc0c222952b43faa3850e9e', 'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_execute_code', 'arguments': '{"code": "import os\\nfrom datetime import datetime, timedelta\\n\\n# Step 1: Analyze memory.md\\nmemory_content = \\"\\"\\"# XiaoPaw 记忆索引\\n\\n> 200 行上限。各主题详见对应 topic 文件，此处只写指针。\\n\\n## 用户偏好\\n→ 详见 user.md（Bootstrap 直接注入，此处不重复）\\n\\"\\"\\"\\nmemory_lines = len(memory_content.split(\'\\\\n\'))\\nmemory_issues = []\\nif memory_lines >= 180:\\n    memory_issues.append({\\n        \\"type\\": \\"near_limit\\",\\n        \\"current_lines\\": memory_lines,\\n        \\"limit\\": 200,\\n        \\"action\\": \\"trigger_governance\\"\\n    })\\n\\n# Check for dead links (none in current memory.md)\\n# No explicit links to check, so no dead_link issues\\n\\n# Step 2: Analyze topic files\\nworkspace_files = [\\n    {\\"name\\": \\"agent.md\\", \\"modified_time\\": 1773736228},\\n    {\\"name\\": \\"memory.md\\", \\"modified_time\\": 1773736228},\\n    {\\"name\\": \\"soul.md\\", \\"modified_time\\": 1773736228},\\n    {\\"name\\": \\"user.md\\", \\"modified_time\\": 1773740533}\\n]\\n\\ntopic_files = []\\ncurrent_time = datetime.now()\\nfor file_info in workspace_files:\\n    if file_info[\\"name\\"] not in [\\"memory.md\\"]:\\n        modified_dt = datetime.fromtimestamp(file_info[\\"modified_time\\"])\\n        days_since = (current_time - modified_dt).days\\n        # Consider files older than 365 days as candidates for archiving\\n        if days_since > 365:\\n            topic_files.append({\\n                \\"file\\": file_info[\\"name\\"],\\n                \\"last_modified\\": modified_dt.strftime(\\"%Y-%m-%d\\"),\\n                \\"days_since\\": days_since,\\n                \\"action\\": \\"archive\\"\\n            })\\n\\n# Step 3: Analyze skills\\nskills_list = [\\n    {\\"name\\": \\"pdf\\", \\"enabled\\": True},\\n    {\\"name\\": \\"docx\\", \\"enabled\\": True},\\n    {\\"name\\": \\"memory-save\\", \\"enabled\\": True},\\n    {\\"name\\": \\"skill-creator\\", \\"enabled\\": True},\\n    {\\"name\\": \\"memory-governance\\", \\"enabled\\": True},\\n    {\\"name\\": \\"analyze-hk-stock\\", \\"enabled\\": True}\\n]\\n\\n# Check for potential duplicates\\n# Based on the loaded skills, we have analyze-hk-stock which seems to be a specific implementation\\n# No obvious duplicates found in the current skill list, but we\'ll check descriptions\\nskill_issues = []\\n\\n# Create analysis report\\nanalysis_report = {\\n    \\"memory_issues\\": memory_issues,\\n    \\"topic_files\\": topic_files,\\n    \\"skill_issues\\": skill_issues\\n}\\n\\nanalysis_report", "language": "python", "timeout": "30"}'}}]}, {'role': 'tool', 'tool_call_id': 'call_1dc0c222952b43faa3850e9e', 'name': 'localhost_8022_mcp_sandbox_execute_code', 'content': '{\n  "status": "ok",\n  "stdout": null,\n  "stderr": null,\n  "exit_code": null\n}'}, {'role': 'user', 'content': 'Analyze the tool result. If requirements are met, provide the Final Answer. Otherwise, call the next tool. Deliver only the answer without meta-commentary.'}], 'temperature': 0.3, 'stop': ['\nObservation:'], 'tools': [{'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_get_browser_info', 'description': 'Get information about browser, like cdp url, viewport size, etc.\n\n    Args:\n        request (Dict): The incoming request context.', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_browser_screenshot', 'description': 'Take a screenshot of the current display.\n\n    Returns:\n        Image: A screenshot of the current display in JPEG format with metadata.', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_browser_execute_action', 'description': "Execute a browser action on the current display.\n\nArgs:\n    `action`: Dictionary containing `action_type` and relevant parameters.\n            The `action_type` determines which parameters are required.\n\nAction types and their parameters (auto-generated from models):\n    - CLICK: {action_type: 'CLICK', x: Optional?, y: Optional?, button: Literal?, num_clicks: Literal?}\n    - DOUBLE_CLICK: {action_type: 'DOUBLE_CLICK', x: Optional?, y: Optional?}\n    - DRAG_REL: {action_type: 'DRAG_REL', x_offset: float, y_offset: float}\n    - DRAG_TO: {action_type: 'DRAG_TO', x: float, y: float}\n    - HOTKEY: {action_type: 'HOTKEY', keys: List}\n    - KEY_DOWN: {action_type: 'KEY_DOWN', key: str}\n    - KEY_UP: {action_type: 'KEY_UP', key: str}\n    - MOUSE_DOWN: {action_type: 'MOUSE_DOWN', button: Literal?}\n    - MOUSE_UP: {action_type: 'MOUSE_UP', button: Literal?}\n    - MOVE_REL: {action_type: 'MOVE_REL', x_offset: float, y_offset: float}\n    - MOVE_TO: {action_type: 'MOVE_TO', x: float, y: float}\n    - PRESS: {action_type: 'PRESS', key: str}\n    - RIGHT_CLICK: {action_type: 'RIGHT_CLICK', x: Optional?, y: Optional?}\n    - SCROLL: {action_type: 'SCROLL', dx: int?, dy: int?}\n    - TYPING: {action_type: 'TYPING', text: str, use_clipboard: Optional?}\n    - WAIT: {action_type: 'WAIT', duration: float}\n\nReturns:\n    Dict containing `status` and `action_performed`\n\nRaises:\n    ValueError: If `action_type` is invalid or required parameters are missing", 'parameters': {'properties': {'action': {'additionalProperties': True, 'description': '', 'title': 'Action', 'type': 'object'}}, 'required': ['action'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_execute_code', 'description': "Execute code in Python or JavaScript runtime.\n\n    Args:\n        code: Code to execute\n        language: Programming language ('python', 'javascript')\n        timeout: Optional execution timeout in seconds\n\n    Returns:\n        Dict containing output, errors, and execution details", 'parameters': {'properties': {'code': {'description': '', 'title': 'Code', 'type': 'string'}, 'language': {'anyOf': [{}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Language'}, 'timeout': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Timeout'}}, 'required': ['code', 'language', 'timeout'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_file_operations', 'description': 'Unified file system operations tool for agents. `/tmp` and `/home/$USER` are fully accessible.\n\n    Args:\n        action: Operation type - "read", "write", "replace", "search", "find", "list"\n        path: File or directory path\n        content: Content for write/replace operations (or regex for search)\n        target: Target string for replace operations (new_str)\n        pattern: Pattern for find operations (glob syntax)\n        encoding: File encoding (utf-8, base64, raw)\n        start_line: Starting line for read operations (0-based)\n        end_line: Ending line for read operations (not included)\n        append: Append mode for write operations\n        recursive: Recursive mode for find/list operations\n        show_hidden: Show hidden files in list operations\n        file_types: Filter by file extensions for list operations\n        sudo: Use sudo privileges\n\n    Returns:\n        Dict containing operation result and relevant data', 'parameters': {'properties': {'action': {'description': '', 'title': 'Action', 'type': 'string'}, 'path': {'description': '', 'title': 'Path', 'type': 'string'}, 'content': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Content'}, 'target': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Target'}, 'pattern': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Pattern'}, 'encoding': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Encoding'}, 'start_line': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Start Line'}, 'end_line': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'End Line'}, 'append': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Append'}, 'recursive': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Recursive'}, 'show_hidden': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Show Hidden'}, 'file_types': {'anyOf': [{}, {'items': {}, 'type': 'array'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'File Types'}, 'sudo': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Sudo'}}, 'required': ['action', 'path', 'content', 'target', 'pattern', 'encoding', 'start_line', 'end_line', 'append', 'recursive', 'show_hidden', 'file_types', 'sudo'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_str_replace_editor', 'description': 'Professional file editor tool using openhands_aci editor.\n\n    This tool provides advanced file editing capabilities compatible with Anthropic\'s\n    str_replace_editor interface. Parameters and behavior match the standard interface.\n\n    Args:\n        command: Command to execute ("view", "create", "str_replace", "insert", "undo_edit")\n        path: File path to operate on\n        file_text: File content for create command\n        old_str: Original string to replace (for str_replace command)\n        new_str: New string to replace with (for str_replace and insert commands)\n        insert_line: Line number to insert at (for insert command)\n        view_range: Line range for view command [start, end]\n\n    Returns:\n        Dict containing editor operation result', 'parameters': {'properties': {'command': {'description': '', 'title': 'Command', 'type': 'string'}, 'path': {'description': '', 'title': 'Path', 'type': 'string'}, 'file_text': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'File Text'}, 'old_str': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Old Str'}, 'new_str': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'New Str'}, 'insert_line': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Insert Line'}, 'view_range': {'anyOf': [{}, {'items': {}, 'type': 'array'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'View Range'}}, 'required': ['command', 'path', 'file_text', 'old_str', 'new_str', 'insert_line', 'view_range'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_get_context', 'description': "Get sandbox environment information. aio system's version.\n\n    Returns:\n        Dict containing aio sandbox's environment info, version, and home directory", 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_get_packages', 'description': "Get installed packages by language.\n\n    Args:\n        language: Optional language filter ('python' or 'nodejs')\n\n    Returns: String listing installed packages", 'parameters': {'properties': {'language': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Language'}}, 'type': 'object', 'additionalProperties': False, 'required': ['language']}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_sandbox_execute_bash', 'description': "Execute a shell command. Sessions are managed automatically.\n\n    Args:\n        cmd: Shell command to execute\n        cwd: Optional working directory (absolute path), default to '/tmp'\n        new_session: If True, creates a new session instead of using the default\n        timeout: Optional timeout in seconds for command execution (default: 30)\n\n    Returns:\n        Dict containing command, status, output, and exit_code", 'parameters': {'properties': {'cmd': {'description': '', 'title': 'Cmd', 'type': 'string'}, 'cwd': {'anyOf': [{}, {'type': 'string'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Cwd'}, 'new_session': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'New Session'}, 'timeout': {'anyOf': [{}, {'type': 'integer'}, {'type': 'null'}], 'default': None, 'description': '', 'title': 'Timeout'}}, 'required': ['cmd', 'cwd',