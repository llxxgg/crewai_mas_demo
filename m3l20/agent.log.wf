ype': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_tab_list', 'description': 'Get the list of tabs', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_switch_tab', 'description': 'Switch to a specific tab', 'parameters': {'properties': {'index': {'description': 'Tab index to switch to', 'title': 'Index', 'type': 'number'}}, 'required': ['index'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_close_tab', 'description': 'Close the current tab', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_evaluate', 'description': 'Execute JavaScript in the browser console', 'parameters': {'properties': {'script': {'description': 'JavaScript code to execute, () => { /* code */ }', 'title': 'Script', 'type': 'string'}}, 'required': ['script'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_vision_screen_capture', 'description': 'Take a screenshot of the current page for vision mode', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_vision_screen_click', 'description': 'Click left mouse button on the page with vision and snapshot, before calling this tool, you should call `browser_vision_screen_capture` first only once, fallback to `browser_click` if failed', 'parameters': {'properties': {'factors': {'anyOf': [{'items': {}, 'type': 'array'}, {'type': 'null'}], 'default': None, 'description': 'Vision model coordinate system scaling factors [width_factor, height_factor] for coordinate space normalization. Transformation formula: x = (x_model * screen_width * width_factor) / width_factor y = (y_model * screen_height * height_factor) / height_factor where x_model, y_model are normalized model output coordinates (0-1), screen_width/height are screen dimensions, width_factor/height_factor are quantization factors, If the factors are unknown, leave it blank. Most models do not require this parameter.', 'title': 'Factors'}, 'x': {'description': 'X pixel coordinate', 'title': 'X', 'type': 'number'}, 'y': {'description': 'Y pixel coordinate', 'title': 'Y', 'type': 'number'}}, 'required': ['factors', 'x', 'y'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_download_list', 'description': 'Get the list of downloaded files', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_screenshot', 'description': 'Take a screenshot of the current page or a specific element', 'parameters': {'properties': {'name': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'Name for the screenshot', 'title': 'Name'}, 'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for element to screenshot', 'title': 'Selector'}, 'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'index of the element to screenshot', 'title': 'Index'}, 'width': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Width in pixels (default: viewport width)', 'title': 'Width'}, 'height': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Height in pixels (default: viewport height)', 'title': 'Height'}, 'fullPage': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description