e": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "vml-wordprocessingDrawing.xsd",\n      "path": "/mnt/skills/pptx/scripts/office/schemas/ISO-IEC29500-4_2016/vml-wordprocessingDrawing.xsd",\n      "is_directory": false,\n      "size": 4010,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "vml-wordprocessingDrawing.xsd",\n      "path": "/mnt/skills/docx/scripts/office/schemas/ISO-IEC29500-4_2016/vml-wordprocessingDrawing.xsd",\n      "is_directory": false,\n      "size": 4010,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml-2010.xsd",\n      "path": "/mnt/skills/xlsx/scripts/office/schemas/microsoft/wml-2010.xsd",\n      "is_directory": false,\n      "size": 26549,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml-2010.xsd",\n      "path": "/mnt/skills/pptx/scripts/office/schemas/microsoft/wml-2010.xsd",\n      "is_directory": false,\n      "size": 26549,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml-2010.xsd",\n      "path": "/mnt/skills/docx/scripts/office/schemas/microsoft/wml-2010.xsd",\n      "is_directory": false,\n      "size": 26549,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml-2012.xsd",\n      "path": "/mnt/skills/xlsx/scripts/office/schemas/microsoft/wml-2012.xsd",\n      "is_directory": false,\n      "size": 3745,\n      "modified_time": "1772458042",\n      "permissions": null,\n      "extension": ".xsd"\n    },\n    {\n      "name": "wml-2012.xsd",\n      "path": "/mnt/skills/pptx/scripts/office/schemas/microsoft/wml-2012.xsd",\n      "is_directory": false,\n      "size": 3745,\n      "modified_time": "1772458