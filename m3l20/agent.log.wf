cp_browser_form_input_fill', 'description': "Fill out an input field, before using the tool, Either 'index' or 'selector' must be provided", 'parameters': {'properties': {'selector': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'CSS selector for input field, priority use index, if index is not provided, use selector', 'title': 'Selector'}, 'index': {'anyOf': [{'type': 'number'}, {'type': 'null'}], 'default': None, 'description': 'Index of the element to fill', 'title': 'Index'}, 'value': {'description': 'Value to fill', 'title': 'Value', 'type': 'string'}, 'clear': {'anyOf': [{'type': 'boolean'}, {'type': 'null'}], 'default': None, 'description': 'Whether to clear existing text before filling', 'title': 'Clear'}}, 'required': ['selector', 'index', 'value', 'clear'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_markdown', 'description': 'Get the markdown content of the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_get_text', 'description': 'Get the text content of the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_read_links', 'description': 'Get all links on the current page', 'parameters': {'properties': {}, 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_new_tab', 'description': 'Open a new tab', 'parameters': {'properties': {'url': {'description': 'URL to open in the new tab', 'title': 'Url', 'type': 'string'}}, 'required': ['url'], 'type': 'object', 'additionalProperties': False}, 'strict': True}}, {'type': 'function', 'function': {'name': 'localhost_8022_mcp_browser_t